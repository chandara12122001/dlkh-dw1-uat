 Name="CASE_STT"><DataField>CASE_STT</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="TOTAL_DIS_AMT"><DataField>TOTAL_DIS_AMT</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field><Field Name="CASE_STT_RMKS"><DataField>CASE_STT_RMKS</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="AUTO_UW_RULE_CD"><DataField>AUTO_UW_RULE_CD</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="AML_CODE"><DataField>AML_CODE</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="STP_CODE"><DataField>STP_CODE</DataField><rd:TypeName>System.String</rd:TypeName></Field></Fields></DataSet><DataSet Name="FailedSTPCode"><Query><DataSourceName>STP</DataSourceName><CommandText>SELECT  
    r.application_number, 
    r.policy_number,
    STRING_AGG(rd.rule_code || ':' || rd.rule_result_code, ',') AS rule_codes
FROM 
    "result" r 
LEFT JOIN 
    result_detail rd 
    ON rd.result_id = r.id 
GROUP BY 
    r.application_number, 
    r.policy_number</CommandText></Query><Fields><Field Name="application_number"><DataField>application_number</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="policy_number"><DataField>policy_number</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="rule_codes"><DataField>rule_codes</DataField><rd:TypeName>System.String</rd:TypeName></Field></Fields></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Tablix Name="Tablix1"><TablixBody><TablixColumns><TablixColumn><Width>0.75in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1.1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1.1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1.5in</Width></TablixColumn><TablixColumn><Width>1.5in</Width></TablixColumn><TablixColumn><Width>0.5in</Width></TablixColumn><TablixColumn><Width>1.3in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1.5in</Width></TablixColumn><TablixColumn><Width>2in</Width></TablixColumn><TablixColumn><Width>1.45139in</Width></TablixColumn><TablixColumn><Width>1.41667in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1.2in</Width></TablixColumn><TablixColumn><Width>0.9in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></Tabl