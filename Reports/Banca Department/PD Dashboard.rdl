,Fields!ORDER_NO.Value = 6, "White"
)</Color></Style></TextRun></TextRuns><Style><TextAlign>Right</TextAlign></Style></Paragraph></Paragraphs><rd:DefaultName>AFYP</rd:DefaultName><Style><Border><Color>#92846e</Color><Style>Solid</Style></Border><BackgroundColor>=
IIF
(
Fields!ORDER_NO.Value &lt;&gt; 6
,"Transparent"
, 
SWITCH
   ((Code.SumLookup(LookupSet(3,Fields!ORDER_NO.Value,Fields!AFYP.Value,"BANCA_SUMMARY_MONTH"))/Code.SumLookup(LookupSet(2,Fields!ORDER_NO.Value,Fields!AFYP.Value,"BANCA_SUMMARY_MONTH"))
)*100 &lt; 60, "Red"

     ,(Code.SumLookup(LookupSet(3,Fields!ORDER_NO.Value,Fields!AFYP.Value,"BANCA_SUMMARY_MONTH"))/Code.SumLookup(LookupSet(2,Fields!ORDER_NO.Value,Fields!AFYP.Value,"BANCA_SUMMARY_MONTH"))
)*100 &lt; 80, "Orange"
     ,(Code.SumLookup(LookupSet(3,Fields!ORDER_NO.Value,Fields!AFYP.Value,"BANCA_SUMMARY_MONTH"))/Code.SumLookup(LookupSet(2,Fields!ORDER_NO.Value,Fields!AFYP.Value,"BANCA_SUMMARY_MONTH"))
)*100 &gt;= 80, "Green"
  
 )

)</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell></TablixCells></TablixRow></TablixRows></TablixBody><TablixColumnHierarchy><TablixMembers><TablixMember><Group Name="BANK_PARTNER2"><GroupExpressions><GroupExpression>=Fields!BANK_PARTNER_ID.Value</GroupExpression></GroupExpressions></Group><SortExpressions><SortExpression><Value>=Fields!BANK_PARTNER_ID.Value</Value></SortExpression></SortExpressions><TablixHeader><Size>0.25in</Size><CellContents><Textbox Name="BANK_PARTNER2"><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!BANK_PARTNER.Value</Value><Style><FontFamily>Arial</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><rd:DefaultName>BANK_PARTNER1</rd:DefaultName><Style><Border><Color>#92846e</Color><Style>Solid</Style></Border><BackgroundColor>#c2b7a8</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixHeader><TablixMembers><TablixMember><Group Name="ColumnGroup2"><GroupExpressions><GroupExpression /></GroupExpressions></Group><TablixMembers><TablixMember><TablixHeader><Size>0.25in</Size><CellContents><Textbox Name="Textbox15"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>#</Value><Style><FontFamily>Arial</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><rd:DefaultName>Textbox13</rd:DefaultName><Style><Border><Color>#92846e</Color><Style>Solid</Style></Border><BackgroundColor>#e2ddd4</BackgroundColor><Ve