<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df"><df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily><AutoRefresh>0</AutoRefresh><DataSources><DataSource Name="SalePortal"><ConnectionProperties><DataProvider>SQL</DataProvider><ConnectString>Data Source=10.116.17.152;Initial Catalog=SalePortal</ConnectString><IntegratedSecurity>true</IntegratedSecurity></ConnectionProperties><rd:SecurityType>Integrated</rd:SecurityType><rd:DataSourceID>6ae08945-4eec-43f0-b82d-fc2dfad62ee1</rd:DataSourceID></DataSource></DataSources><DataSets><DataSet Name="DataSet1"><Query><DataSourceName>SalePortal</DataSourceName><QueryParameters><QueryParameter Name="@chanel"><Value>=Parameters!chanel.Value</Value></QueryParameter></QueryParameters><CommandText>
select 
ma.username as manager_username,
CONCAT(ma.last_name,' ',ma.first_name) as manager_name,
ag.username as agent_username,
CONCAT(ag.last_name,' ',ag.first_name) as fafp_name,
count(a.status) as case_amount
,case when p.pending &gt; 0 then p.pending else 0 end as pending
,case when s.submitted &gt; 0 then s.submitted else 0 end as submitted
,case when r.rejected &gt; 0 then r.rejected else 0 end as rejected
from applications a
left join user_profiles ag on ag.user_id = a.updated_by
left join user_profiles ma on ma.user_id = ag.application_reviewer_id
left join (
	select ag.username,ag.user_id, COUNT(status) as pending from applications a 
	left join user_profiles ag on ag.user_id = a.updated_by where a.status = 'P' and a.channel = @chanel
	group by ag.username,ag.user_id
) p on p.user_id = ag.user_id
left join (
	select ag.username,ag.user_id, COUNT(status) as submitted from applications a 
	left join user_profiles ag on ag.user_id = a.updated_by where a.status = 'S' and a.channel = @chanel
	group by ag.username,ag.user_id
) s on s.user_id = ag.user_id
left join (
	select ag.username,ag.user_id, COUNT(status) as rejected from applications a 
	left join user_profiles ag on ag.user_id = a.updated_by where a.status = 'R' and a.channel = @chanel
	group by ag.username,ag.user_id
) r on r.user_id = ag.user_id
where a.status IN ('S','R','P') 
and ma.username is not null
and a.channel = @chanel
GROUP BY ma.username,ag.username,ma.last_name,ma.first_name,ag.first_name,ag.last_name,p.pending,s.submitted,r.rejected</CommandText></Query><Fields><Field Name="manager_username"><DataField>manager_username</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="manager_name"><DataField>manager_name</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="agent_username"><DataField>agent_username</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="fafp_name"><DataField>fafp_name</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="case_amount"><DataField>case_amount</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="pending"><DataField>pending</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="submitted"><DataField>submitted</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="rejected"><DataField>rejected</DataField><rd:TypeName>System.Int32</rd:TypeName></Field></Fields></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Textbox Name="ReportTitle"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>Application Submit in Hand by Reviewer</Value><Style><FontFamily>Arial</FontFamily><FontSize>12pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs><rd:WatermarkTextbox>Title</rd:WatermarkTextbox><rd:DefaultName>ReportTitle</rd:DefaultName><Height>0.4in</Height><Width>8in</Width><Style><Border><Color>#c2b7a8</Color><Style>None</Style></Border><BottomBorder><Style>Solid</Style><Width>2pt</Width></BottomBorder><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox><Tablix Name="Tablix3"><TablixBody><TablixColumns><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn></TablixColumns><TablixRows><TablixRow><Height>0.3in</Height><TablixCells><TablixCell><CellContents><Textbox Name="Textbox122"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>Pending</Value><Style><FontFamily>Arial</FontFamily><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><rd:DefaultName>Textbox122</rd:DefaultName><Style><Border><Color>#92846e</Color><Style>Solid</Style></Border><BackgroundColor>#c2b7a8</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell><TablixCell><CellContents><Textbox Name="Textbox124"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>Suubmitted </Value><Style><FontFamily>Arial</FontFamily><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><rd:DefaultName>Textbox124</rd:DefaultName><Style><Border><Color>#92846e</Color><Style>Solid</Style></Border><BackgroundColor>#c2b7a8</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell><TablixCell><CellContents><Textbox Name="Textbox126"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>Rejected</Value><Style><FontFamily>Arial</FontFamily><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><rd:DefaultName>Textbox126</rd:DefaultName><Style><Border><Color>#92846e</Color><Style>Solid</Style></Border><BackgroundColor>#c2b7a8</BackgroundColor><VerticalAlign>Middle</Verti