<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df"><df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily><AutoRefresh>0</AutoRefresh><DataSources><DataSource Name="DataSource1"><ConnectionProperties><DataProvider>SQL</DataProvider><ConnectString>Data Source=10.116.17.152;Initial Catalog=SalePortal</ConnectString><IntegratedSecurity>true</IntegratedSecurity></ConnectionProperties><rd:SecurityType>Integrated</rd:SecurityType><rd:DataSourceID>b5b81407-8ba8-42bc-bd42-d8f29c7a6835</rd:DataSourceID></DataSource></DataSources><DataSets><DataSet Name="APP_DETAIL"><Query><DataSourceName>DataSource1</DataSourceName><QueryParameters><QueryParameter Name="@START"><Value>=Parameters!START.Value</Value></QueryParameter><QueryParameter Name="@END"><Value>=Parameters!END.Value</Value></QueryParameter></QueryParameters><CommandText>
SELECT A.number APP_NUM
,A.policy_id POL_ID
,PD.name_en PRODUCT_NAME
,A.po_name PO_NAME
,SUBMISSION_DATE =  CONVERT(DATE,SUBD.SUBMIT_DATE)
,APPROVED_DATE = CASE WHEN STC.status = 'S' THEN CONVERT(DATE,STC.CHANGE_DATE) ELSE NULL END
,REJECTED_DATE = CASE WHEN STC.status = 'R' THEN CONVERT(DATE,STC.CHANGE_DATE) ELSE NULL END
,PM.code PAYMENT_MODE
,ST.name_en AS STATUS
,FYP = CASE WHEN BE.factor_type = 'AP' THEN BE.FYP/2 ELSE BE.FYP END
,AFYP = CASE WHEN BE.factor_type = 'AP' THEN BE.AFYP/2 ELSE BE.AFYP END
,FA.agent_id
,RTRIM(FA.last_name)+' '+RTRIM(FA.first_name) FA_NAME
,AG.BMNAME BBM_NAME
,SB.name_en BRANCH_NAME
,AG.PARTNERNAME  BANK_NAME
,RTRIM(A.reject_reason) REJECT_REASON
FROM applications A
LEFT JOIN quotations QU ON QU.id = A.quotation_id
LEFT JOIN payment_frequencies PM ON PM.id = QU.payment_frequency_id
LEFT JOIN products PD on PD.id = a.product_id
LEFT JOIN user_profiles FA ON FA.user_id = A.updated_by
LEFT JOIN AGENT_DETAIL AG ON AG.AgentId = FA.agent_id
LEFT JOIN (
	SELECT L.quotation_id, SUM(B.modal_premium_amount) AS FYP, SUM(B.premium_amount) AS AFYP,B.factor_type  FROM life_insureds L
	LEFT JOIN benefits B ON B.life_insured_id = L.id
	GROUP BY L.quotation_id, B.factor_type
) BE ON BE.quotation_id = A.quotation_id
LEFT JOIN system_defined_field_lists ST ON ST.code = A.status AND ST.system_defined_field_code = 'app-status'
LEFT JOIN referrals RE ON RE.application_id = A.id
LEFT JOIN user_defined_field_lists SB ON SB.code = RE.sold_branch AND SB.user_defined_field_code = 'sold-branch'
LEFT JOIN (SELECT ROW_NUMBER() OVER(PARTITION BY application_id ORDER BY updated_at DESC) AS ROW_NUM, application_id, status, updated_at AS CHANGE_DATE FROM application_status_changes) STC ON STC.application_id = A.ID AND STC.ROW_NUM = 1
LEFT JOIN (SELECT ROW_NUMBER() OVER(PARTITION BY application_id ORDER BY updated_at DESC) AS ROW_NUM, application_id, status, updated_at AS SUBMIT_DATE FROM application_status_changes WHERE status = 'P') SUBD ON SUBD.application_id = A.ID AND SUBD.ROW_NUM = 1
WHERE FA.channel = 'B' AND A.status != 'D' 
AND CONVERT(DATE,A.updated_at) BETWEEN @START AND @END </CommandText></Query><Fields><Field Name="APP_NUM"><DataField>APP_NUM</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="POL_ID"><DataField>POL_ID</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="PRODUCT_NAME"><DataField>PRODUCT_NAME</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="PO_NAME"><DataField>PO_NAME</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="SUBMISSION_DATE"><DataField>SUBMISSION_DATE</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field><Field Name="APPROVED_DATE"><DataField>APPROVED_DATE</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field><Field Name="REJECTED_DATE"><DataField>REJECTED_DATE</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field><Field Name="PAYMENT_MODE"><DataField>PAYMENT_MODE</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="STATUS"><DataField>STATUS</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="FYP"><DataField>FYP</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field><Field Name="AFYP"><DataField>AFYP</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field><Field Name="FA_NAME"><DataField>FA_NAME</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="BBM_NAME"><DataField>BBM_NAME</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="BRANCH_NAME"><DataField>BRANCH_NAME</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="BANK_NAME"><DataField>BANK_NAME</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="REJECT_REASON"><DataField>REJECT_REASON</DataField><rd:TypeName>System.String</rd:TypeName></Field></Fields></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Textbox Name="ReportTitle"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>EPOS Application Detail (LIVE)</Value><Style><FontFamily>Arial</FontFamily><FontSize>12pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs><rd:WatermarkTextbox>Title</rd:WatermarkTextbox><rd:DefaultName>ReportTitle</rd:DefaultName><Height>0.37in</Height><Width>14.3in</Width><Style><Border><Style>None</Style></Border><TopBorder><Width>10pt</Width></TopBorder><BottomBorder><Style>None</Style></BottomBorder><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox><Line Name="Line1"><Top>0.42in</Top><Height>0in</Height><Width>22.06667in</Width><ZIndex>1</ZIndex><Style><Border><Style>Solid</Style><Width>3pt</Width></Border></Style></Line><Tablix Name="Tablix1"><TablixBody><TablixColumns><TablixColumn><Width>1.2in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1.5in</Width></TablixColumn><TablixColumn><Width>1.8in</Width></TablixColumn><TablixColumn><Width>1.16667in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1.2in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1.8in</Width></TablixColumn><TablixColumn><Width>1.8in</Width></TablixColumn><TablixColumn><Width>2.5in</Width></TablixColumn><TablixColumn><Width>1.8in</Width></TablixColumn><TablixColumn><Width>3in</Width></TablixColumn></TablixColumns><TablixRows><TablixRow><Height>0.25in</Height><TablixCells><TablixCell><CellContents><Textbox Name="Textbox46"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>Report Date: </Value><Style><FontFamily>Arial</FontFamily></Style></TextRun><TextRun><Label>start</Label><Value>=Parameters!START.Value</Value><Style><Fon