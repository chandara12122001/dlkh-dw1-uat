<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df"><df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily><AutoRefresh>0</AutoRefresh><DataSources><DataSource Name="DataSource1"><ConnectionProperties><DataProvider>SQL</DataProvider><ConnectString>Data Source=10.116.17.152;Initial Catalog=SalePortal</ConnectString><IntegratedSecurity>true</IntegratedSecurity></ConnectionProperties><rd:SecurityType>Integrated</rd:SecurityType><rd:DataSourceID>b5b81407-8ba8-42bc-bd42-d8f29c7a6835</rd:DataSourceID></DataSource></DataSources><DataSets><DataSet Name="MTD_LIVE"><Query><DataSourceName>DataSource1</DataSourceName><CommandText>



DROP TABLE IF EXISTS #TEMP
DROP TABLE IF EXISTS #FINAL


SELECT ORDER_NO = 1, STATUS = 'Submitted'
INTO #TEMP
UNION SELECT ORDER_NO = 2, STATUS = 'Pending'
UNION SELECT ORDER_NO = 3 , STATUS = 'Rejected'

SELECT A.number APP_NUM
,A.status APP_STATUS
,ST.name_en AS STATUS_DESC
,A.quotation_id
,BE.FYP
,BE.AFYP
,BANK_ID = AG.PARTNERID
,BANK_NAME = AG.PARTNERNAME
INTO #FINAL
FROM applications A
LEFT JOIN user_profiles U ON U.user_id = A.updated_by
LEFT JOIN user_profiles MV ON MV.user_id = U.application_reviewer_id AND MV.enable = 1 AND MV.username NOT IN ('manager','reviewer_sreymom')
LEFT JOIN AGENT_DETAIL AG ON AG.AgentId = U.agent_id
LEFT JOIN (
	SELECT L.quotation_id, SUM(B.modal_premium_amount) AS FYP, SUM(B.premium_amount) AS AFYP  FROM life_insureds L
	LEFT JOIN benefits B ON B.life_insured_id = L.id
	GROUP BY L.quotation_id
) BE ON BE.quotation_id = A.quotation_id
LEFT JOIN system_defined_field_lists ST ON ST.code = A.status AND ST.system_defined_field_code = 'app-status'
WHERE U.channel = 'B' AND A.status != 'D' AND MV.username IS NOT NULL 
AND CONVERT(DATE,A.updated_at) BETWEEN CONVERT(DATE,DATEADD(DAY,-DAY(GETDATE()) + 1,GETDATE())) AND CONVERT(DATE,GETDATE())

SELECT DISTINCT APP_NUM
,APP.APP_STATUS
,ISNULL(APP.FYP,0) FYP
,ISNULL(APP.AFYP,0) AFYP
,T.ORDER_NO
,T.STATUS
,APP.BANK_ID
,APP.BANK_NAME
FROM (
	-- SUBMITTED APP
	SELECT ORDER_NO = 1, F.APP_NUM, F.AFYP,F.FYP,F.APP_STATUS,F.BANK_ID,F.BANK_NAME
	FROM #FINAL F WHERE F.APP_STATUS = 'S'
	

	UNION ALL
	--PENDING
	SELECT ORDER_NO = 2, F.APP_NUM, F.AFYP,F.FYP,F.APP_STATUS,F.BANK_ID,F.BANK_NAME
	FROM #FINAL F WHERE F.APP_STATUS = 'P'

	UNION ALL 
	--REJECTED
	SELECT ORDER_NO = 3, F.APP_NUM, F.AFYP,F.FYP,F.APP_STATUS,F.BANK_ID,F.BANK_NAME
	FROM #FINAL F WHERE F.APP_STATUS = 'R'
	
) APP
RIGHT JOIN #TEMP T ON T.ORDER_NO = APP.ORDER_NO</CommandText></Query><Fields><Field Name="APP_NUM"><DataField>APP_NUM</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="APP_STATUS"><DataField>APP_STATUS</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="ORDER_NO"><DataField>ORDER_NO</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="status"><DataField>STATUS</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="BANK_ID"><DataField>BANK_ID</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="FYP"><DataField>FYP</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field><Field Name="AFYP"><DataField>AFYP</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field><Field Name="BANK_NAME"><DataField>BANK_NAME</DataField><rd:TypeName>System.String</rd:TypeName></Field></Fields></DataSet><DataSet Name="MTD_MANAGER_REVIEW"><Query><DataSourceName>DataSource1</DataSourceName><CommandText>


DROP TABLE IF EXISTS #TEMP
DROP TABLE IF EXISTS #FINAL


SELECT ORDER_NO = 1, STATUS = 'Submitted'
INTO #TEMP
UNION SELECT ORDER_NO = 2, STATUS = 'Pending'
UNION SELECT ORDER_NO = 3 , STATUS = 'Rejected'


SELECT A.number APP_NUM
,A.status APP_STATUS
,ST.name_en AS STATUS_DESC
,A.quotation_id
,BE.FYP
,BE.AFYP
,MV.username USERNAME
,MV.user_id MR_ID
INTO #FINAL
FROM applications A
LEFT JOIN user_profiles U ON U.user_id = A.updated_by
LEFT JOIN user_profiles MV ON MV.user_id = U.application_reviewer_id AND MV.enable = 1 AND MV.username NOT IN ('manager','reviewer_sreymom')
LEFT JOIN (
	SELECT L.quotation_id, SUM(B.modal_premium_amount) AS FYP, SUM(B.premium_amount) AS AFYP  FROM life_insureds L
	LEFT JOIN benefits B ON B.life_insured_id = L.id
	GROUP BY L.quotation_id
) BE ON BE.quotation_id = A.quotation_id
LEFT JOIN system_defined_field_lists ST ON ST.code = A.status AND ST.system_defined_field_code = 'app-status'
WHERE U.channel = 'B' AND A.status != 'D' AND MV.username IS NOT NULL AND CONVERT(DATE,A.updated_at) BETWEEN CONVERT(DATE,DATEADD(DAY,-DAY(GETDATE()) + 1,GETDATE())) AND CONVERT(DATE,GETDATE())


SELECT APP.APP_STATUS
,ISNULL(APP.FYP,0) FYP
,ISNULL(APP.AFYP,0) AFYP
,T.ORDER_NO
,T.STATUS
,APP.username  USERNAME
,APP.MANAGER_NAME 
FROM (
	-- SUBMITTED APP
	SELECT ORDER_NO = 1, F.AFYP,F.FYP,F.APP_STATUS,MR.username, MR.last_name+ ' '+MR.first_name MANAGER_NAME
	FROM #FINAL F
	RIGHT JOIN (SELECT * FROM user_profiles WHERE role_profile_id = 2 AND channel = 'B' AND enable = 1 AND username NOT IN ('manager','reviewer_sreymom')) MR ON MR.USER_ID = F.MR_ID AND F.APP_STATUS = 'S'

	UNION ALL
	--PENDING
	SELECT ORDER_NO = 2, F.AFYP,F.FYP,F.APP_STATUS,MR.username, MR.last_name+ ' '+MR.first_name MANAGER_NAME
	FROM #FINAL F
	RIGHT JOIN (SELECT * FROM user_profiles WHERE role_profile_id = 2 AND channel = 'B' AND enable = 1 AND username NOT IN ('manager','reviewer_sreymom')) MR ON MR.USER_ID = F.MR_ID AND F.APP_STATUS = 'P'

	UNION ALL 
	--REJECTED
	SELECT ORDER_NO = 3, F.AFYP,F.FYP,F.APP_STATUS,MR.username, MR.last_name+ ' '+MR.first_name MANAGER_NAME
	FROM #FINAL F
	RIGHT JOIN (SELECT * FROM user_profiles WHERE role_profile_id = 2 AND channel = 'B'AND enable = 1 AND username NOT IN ('manager','reviewer_sreymom')) MR ON MR.USER_ID = F.MR_ID AND F.APP_STATUS = 'R'

) APP
RIGHT JOIN #TEMP T ON T.ORDER_NO = APP.ORDER_NO</CommandText></Query><Fields><Field Name="APP_STATUS"><DataField>APP_STATUS</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="status"><DataField>STATUS</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="ORDER_NO"><DataField>ORDER_NO</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="FYP"><DataField>FYP</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field><Field Name="AFYP"><DataField>AFYP</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field><Field Name="USERNAME"><DataField>USERNAME</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="MANAGER_NAME"><DataField>MANAGER_NAME</DataField><rd:TypeName>System.String</rd:TypeName></Field></Fields></DataSet><DataSet Name="DAY_LIVE"><Query><DataSourceName>DataSource1</DataSourceName><CommandText>





DROP TABLE IF EXISTS #TEMP
DROP TABLE IF EXISTS #FINAL


SELECT ORDER_NO = 1, STATUS = 'Submitted'
INTO #TEMP
UNION SELECT ORDER_NO = 2, STATUS = 'Pending'
UNION SELECT ORDER_NO = 3 , STATUS = 'Rejected'

SELECT A.number APP_NUM
,A.status APP_STATUS
,ST.name_en AS STATUS_DESC
,A.quotation_id
,BE.FYP
,BE.AFYP
,BANK_ID = AG.PARTNERID
,BANK_NAME = AG.PARTNERNAME
INTO #FINAL
FROM applications A
LEFT JOIN user_profiles U ON U.user_id = A.updated_by
LEFT JOIN AGENT_DETAIL AG ON AG.AgentId = U.agent_id
LEFT JOIN (
	SELECT L.quotation_id, SUM(B.modal_premium_amount) AS FYP, SUM(B.premium_amount) AS AFYP  FROM life_insureds L
	LEFT JOIN benefits B ON B.life_insured_id = L.id
	GROUP BY L.quotation_id
) BE ON BE.quotation_id = A.quotation_id
LEFT JOIN system_defined_field_lists ST ON ST.code = A.status AND ST.system_defined_field_code = 'app-status'
WHERE U.channel = 'B' AND A.status != 'D' AND CONVERT(DATE,A.updated_at) = CONVERT(DATE,GETDATE())

SELECT DISTINCT APP_NUM
,APP.APP_STATUS
,ISNULL(APP.FYP,0) FYP
,ISNULL(APP.AFYP,0) AFYP
,T.ORDER_NO
,T.STATUS
,APP.BANK_ID
,APP.BANK_NAME
FROM (
	-- SUBMITTED APP
	SELECT ORDER_NO = 1, F.APP_NUM, F.AFYP,F.FYP,F.APP_STATUS,F.BANK_ID,F.BANK_NAME
	FROM #FINAL F WHERE F.APP_STATUS = 'S'
	

	UNION ALL
	--PENDING
	SELECT ORDER_NO = 2, F.APP_NUM, F.AFYP,F.FYP,F.APP_STATUS,F.BANK_ID,F.BANK_NAME
	FROM #FINAL F WHERE F.APP_STATUS = 'P'

	UNION ALL 
	--REJECTED
	SELECT ORDER_NO = 3, F.APP_NUM, F.AFYP,F.FYP,F.APP_STATUS,F.BANK_ID,F.BANK_NAME
	FROM #FINAL F WHERE F.APP_STATUS = 'R'
) APP
RIGHT JOIN #TEMP T ON T.ORDER_NO = APP.ORDER_NO</CommandText></Query><Fields><Field Name="APP_NUM"><DataField>APP_NUM</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="APP_STATUS"><DataField>APP_STATUS</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="ORDER_NO"><DataField>ORDER_NO</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="FYP"><DataField>FYP</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field><Field Name="BANK_ID"><DataField>BANK_ID</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="AFYP"><DataField>AFYP</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field><Field Name="STATUS"><DataField>STATUS</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="BANK_NAME"><DataField>BANK_NAME</DataField><rd:TypeName>System.String</rd:TypeName></Field></Fields></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Textbox Name="ReportTitle"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>EPOS Application Dashboard (LIVE)</Value><Style><FontFamily>Arial</FontFamily><FontSize>12pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs><rd:WatermarkTextbox>Title</rd:WatermarkTextbox><rd:DefaultName>ReportTitle</rd:DefaultName><Left>0.2in</Left><Height>0.37in</Height><Width>14.3in</Width><Style><Border><Style>None</Style></Border><TopBorder><Width>10pt</Width></TopBorder><BottomBorder><Style>None</Style></BottomBorder><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox><Tablix Name="Tablix1"><TablixCorner><TablixCornerRows><TablixCornerRow><TablixCornerCell><CellContents><Textbox Name="Textbox19"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>DAY (Real-time)</