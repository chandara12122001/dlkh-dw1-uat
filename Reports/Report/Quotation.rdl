<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df"><df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily><AutoRefresh>0</AutoRefresh><DataSources><DataSource Name="DataSource1"><DataSourceReference>OMNI</DataSourceReference><rd:SecurityType>None</rd:SecurityType><rd:DataSourceID>7cb9e9c6-9052-4701-8224-295bdb533f1d</rd:DataSourceID></DataSource></DataSources><DataSets><DataSet Name="Quotation"><Query><DataSourceName>DataSource1</DataSourceName><QueryParameters><QueryParameter Name="@QuotationId"><Value>=Parameters!QuotationId.Value</Value></QueryParameter><QueryParameter Name="QuoationId"><Value>=Parameters!QuotationId.Value</Value><rd:UserDefined>true</rd:UserDefined></QueryParameter></QueryParameters><CommandText>SELECT P.LastName,P.FirstName,P.Gender,P.DateOfBirth,P.Age 
FROM Quotation Q
INNER JOIN Person P ON Q.ProposerId=P.PersonId
WHERE QuotationId= @QuotationId</CommandText></Query><Fields><Field Name="FirstName"><DataField>FirstName</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="Gender"><DataField>Gender</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="LastName"><DataField>LastName</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="DateOfBirth"><DataField>DateOfBirth</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field><Field Name="Age"><DataField>Age</DataField><rd:TypeName>System.Int16</rd:TypeName></Field></Fields></DataSet><DataSet Name="LifeInsured"><Query><DataSourceName>DataSource1</DataSourceName><QueryParameters><QueryParameter Name="@QuotationId"><Value>=Parameters!QuotationId.Value</Value></QueryParameter></QueryParameters><CommandText>select P.LastName,P.FirstName,P.Gender,P.DateOfBirth,Age 
from  QuotationLifeInsured QL 
INNER JOIN Person P ON QL.PersonId=P.PersonID
where QL.QuotationId=@QuotationId
order by QL.LifeInsuredNumber</CommandText></Query><Fields><Field Name="FirstName"><DataField>FirstName</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="Gender"><DataField>Gender</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="LastName"><DataField>LastName</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="DateOfBirth"><DataField>DateOfBirth</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field><Field Name="Age"><DataField>Age</DataField><rd:TypeName>System.Int16</rd:TypeName></Field></Fields></DataSet><DataSet Name="Benefit"><Query><DataSourceName>DataSource1</DataSourceName><QueryParameters><QueryParameter Name="@QuotationId"><Value>=Parameters!QuotationId.Value</Value></QueryParameter></QueryParameters><CommandText>SELECT B.Name AS BenefitName, P.LastName,P.FirstName,QB.PolicyTerm,
QB.PremiumTerm,QB.SumInsured,ROUND(QB.PremiumAmount,2) AS PremiumAmount,
QB.SumInsured*JL.AccidentailBenefit*JL.ADB AS AccidentalBenefit,
QB.SumInsured*JL.NonAccidentailBenefit*JL.NADB AS NonAccidentalBenefit,
QB.SumInsured*ACB.TotalRate AS ACB,
QB.SumInsured*B.MaturityBenefit AS MaturityBenefitAmount
FROM QuotationBenefit QB
INNER JOIN QuotationLifeInsured QL ON QB.QuotationLifeInsuredId=QL.QuotationLifeInsuredId
INNER JOIN  Person P ON QL.PersonId=P.PersonId
INNER JOIN Quotation Q ON QL.QuotationId=Q.QuotationId
INNER JOIN Benefit B ON QB.BenefitId=B.BenefitId
LEFT JOIN (SELECT AC.BenefitId,AC.PolicyTerm, SUM(AC.Rate) AS TotalRate FROM AdvancedCashBackBenefit AC WHERE AC.BenefitId=1 GROUP BY AC.BenefitId,AC.PolicyTerm) AS ACB ON QB.BenefitId=ACB.BenefitId AND QB.PolicyTerm=ACB.PolicyTerm
LEFT JOIN JuvenileLien JL ON JL.BenefitId=QB.BenefitId AND JL.AgeFrom&lt;=P.Age AND JL.AgeTo&gt;=P.Age
WHERE Q.QuotationId=@QuotationId
ORDER BY QL.LifeInsuredNumber, QB.BenefitNumber</CommandText></Query><Fields><Field Name="BenefitName"><DataField>BenefitName</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="LastName"><DataField>LastName</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="FirstName"><DataField>FirstName</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="PolicyTerm"><DataField>PolicyTerm</DataField><rd:TypeName>System.Int16</rd:TypeName></Field><Field Name="PremiumTerm"><DataField>PremiumTerm</DataField><rd:TypeName>System.Int16</rd:TypeName></Field><Field Name="SumInsured"><DataField>SumInsured</DataField><rd:TypeName>System.Double</rd:TypeName></Field><Field Name="PremiumAmount"><DataField>PremiumAmount</DataField><rd:TypeName>System.Double</rd:TypeName></Field><Field Name="AccidentalBenefit"><DataField>AccidentalBenefit</DataField><rd:TypeName>System.Double</rd:TypeName></Field><Field Name="NonAccidentalBenefit"><DataField>NonAccidentalBenefit</DataField><rd:TypeName>System.Double</rd:TypeName></Field><Field Name="ACB"><DataField>ACB</DataField><rd:TypeName>System.Double</rd:TypeName></Field><Field Name="MaturityBenefitAmount"><DataField>MaturityBenefitAmount</DataField><rd:TypeName>System.Double</rd:TypeName></Field></Fields></DataSet><DataSet Name="Illustration"><Query><DataSourceName>DataSource1</DataSourceName><QueryParameters><QueryParameter Name="@QuotationId"><Value>=Parameters!QuotationId.Value</Value></QueryParameter></QueryParameters><CommandText>DECLARE @StartYear INT
DECLARE @PolicyTerm INT
DECLARE @QuotationBenefitId binary(255)

SET @StartYear = 1;
SET @PolicyTerm = (SELECT QB.PolicyTerm FROM QuotationBenefit QB INNER JOIN QuotationLifeInsured QL ON QB.QuotationLifeInsuredId=QL.QuotationLifeInsuredId WHERE QL.QuotationId=@QuotationId AND QB.BenefitNumber=1)
SET @QuotationBenefitId = (SELECT QB.QuotationBenefitId FROM QuotationBenefit QB INNER JOIN QuotationLifeInsured QL ON QB.QuotationLifeInsuredId=QL.QuotationLifeInsuredId WHERE QL.QuotationId=@QuotationId AND QB.BenefitNumber=1)

;WITH BasicBenefit AS (
    SELECT @StartYear AS PolicyYear, @QuotationBenefitId AS QuotationBenefitId
    UNION ALL
    SELECT PolicyYear+1 , @QuotationBenefitId AS QuoationBenefitId FROM BasicBenefit WHERE PolicyYear+1&lt;=@PolicyTerm
)
SELECT BB.PolicyYear,
P.Age+BB.PolicyYear-1 AS Age,
ROUND(QB.PremiumAmount,2) AS PremiumAmount,
QB.SumInsured*JL.AccidentailBenefit*JL.ADB AS AccidentalBenefit,
QB.SumInsured*JL.NonAccidentailBenefit*JL.NADB AS NonAccidentalBenefit,
ISNULL(QB.SumInsured*ACB.Rate,0) AS ACB,
ISNULL(QB.SumInsured*SB.Rate,0) AS Surrender
FROM BasicBenefit BB
INNER JOIN QuotationBenefit QB ON BB.QuotationBenefitId=QB.QuotationBenefitId
INNER JOIN QuotationLifeInsured QL ON QB.QuotationLifeInsuredId=QL.QuotationLifeInsuredId
INNER JOIN Person P ON QL.PersonId=P.PersonId
--INNER JOIN Quotation Q ON QL.QuotationId=Q.QuotationId
INNER JOIN Benefit B ON QB.BenefitId=B.BenefitId
LEFT JOIN AdvancedCashBackBenefit ACB ON QB.BenefitId=ACB.BenefitId AND QB.PolicyTerm = ACB.PolicyTerm AND BB.PolicyYear=ACB.PolicyYear
--LEFT JOIN (SELECT AC.BenefitId,AC.PolicyTerm, SUM(AC.Rate) AS TotalRate FROM AdvancedCashBackBenefit AC WHERE AC.BenefitId=1 GROUP BY AC.BenefitId,AC.PolicyTerm) AS ACB ON QB.BenefitId=ACB.BenefitId AND QB.PolicyTerm=ACB.PolicyTerm
LEFT JOIN JuvenileLien JL ON JL.BenefitId=QB.BenefitId AND JL.AgeFrom&lt;=P.Age AND JL.AgeTo&gt;=P.Age
LEFT JOIN SurrenderBenefit SB ON SB.BenefitId=QB.BenefitId AND SB.PolicyTerm=QB.PolicyTerm AND SB.PolicyYear=BB.PolicyYear
ORDER BY QL.LifeInsuredNumber, QB.BenefitNumber</CommandText></Query><Fields><Field Name="PolicyYear"><DataField>PolicyYear</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="Age"><DataField>Age</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="PremiumAmount"><DataField>PremiumAmount</DataField><rd:TypeName>System.Double</rd:TypeName></Field><Field Name="AccidentalBenefit"><DataField>AccidentalBenefit</DataField><rd:TypeName>System.Double</rd:TypeName></Field><Field Name="NonAccidentalBenefit"><DataField>NonAccidentalBenefit</DataField><rd:TypeName>System.Double</rd:TypeName></Field><Field Name="ACB"><DataField>ACB</DataField><rd:TypeName>System.Double</rd:TypeName></Field><Field Name="Surrender"><DataField>Surrender</DataField><rd:TypeName>System.Double</rd:TypeName></Field></Fields></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Textbox Name="Textbox2"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>Sales Illustration</Value><Style><FontFamily>calibri light</FontFamily><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><rd:DefaultName>Textbox2</rd:DefaultName><Top>0.02526in</Top><Left>0.22167in</Left><Height>0.25in</Height><Width>7.8in</Width><Style><Border><Style>None</Style></Border><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox><Tablix Name="Tablix1"><TablixBody><TablixColumns><TablixColumn><Width>3.38333in</Width></TablixColumn><TablixColumn><Width>2.29538in</Width></TablixColumn><TablixColumn><Width>0.91759in</Width></TablixColumn><TablixColumn><Width>1.2037in</Width></TablixColumn></TablixColumns><TablixRows><TablixRow><Height>0.25in</Height><TablixCells><TablixCell><CellContents><Textbox Name="Textbox15"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraph