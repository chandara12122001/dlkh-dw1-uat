                              <TextRuns>
                                <TextRun>
                                  <Label>REQIR_DESC</Label>
                                  <Value>=join
(
	Lookupset
	(
		Fields!POL_ID.Value
		,Fields!POL_ID.Value
		,REPLACE(TRIM(Fields!ETBL_DESC_TXT.Value),";",vbcrlf &amp; "- ")
		,"DataSet2"
	)
	," " &amp; vbcrlf
)</Value>
                                  <Style>
