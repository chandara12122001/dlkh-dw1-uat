l</rd:TypeName><DataField>ORIGINAL_PRM</DataField></Field><Field Name="AUTO_DIS"><rd:TypeName>System.Decimal</rd:TypeName><DataField>AUTO_DIS</DataField></Field><Field Name="MAN_DIS"><rd:TypeName>System.Decimal</rd:TypeName><DataField>MAN_DIS</DataField></Field><Field Name="AML_CODE"><rd:TypeName>System.String</rd:TypeName><DataField>AML_CODE</DataField></Field><Field Name="STP_CODE"><rd:TypeName>System.String</rd:TypeName><DataField>STP_CODE</DataField></Field><Field Name="TOTAL_DIS_AMT"><rd:TypeName>System.Decimal</rd:TypeName><DataField>TOTAL_DIS_AMT</DataField></Field><Field Name="PONAME"><rd:TypeName>System.String</rd:TypeName><DataField>PONAME</DataField></Field><Field Name="POCLI"><rd:TypeName>System.String</rd:TypeName><DataField>POCLI</DataField></Field><Field Name="POPHONE"><rd:TypeName>System.String</rd:TypeName><DataField>POPHONE</DataField></Field><Field Name="PO_AGE"><rd:TypeName>System.Int32</rd:TypeName><DataField>PO_AGE</DataField></Field><Field Name="ALNAME1"><rd:TypeName>System.String</rd:TypeName><DataField>ALNAME1</DataField></Field><Field Name="ALCLI1"><rd:TypeName>System.String</rd:TypeName><DataField>ALCLI1</DataField></Field><Field Name="ALPHONE1"><rd:TypeName>System.String</rd:TypeName><DataField>ALPHONE1</DataField></Field><Field Name="ALI1_AGE"><rd:TypeName>System.Int32</rd:TypeName><DataField>ALI1_AGE</DataField></Field><Field Name="ALNAME2"><rd:TypeName>System.String</rd:TypeName><DataField>ALNAME2</DataField></Field><Field Name="ALCLI2"><rd:TypeName>System.String</rd:TypeName><DataField>ALCLI2</DataField></Field><Field Name="ALPHONE2"><rd:TypeName>System.String</rd:TypeName><DataField>ALPHONE2</DataField></Field><Field Name="ALI2_AGE"><rd:TypeName>System.Int32</rd:TypeName><DataField>ALI2_AGE</DataField></Field></Fields></DataSet><DataSet Name="DataSet2"><Query><DataSourceName>UAT_STAGE</DataSourceName><CommandType>StoredProcedure</CommandType><CommandText>PARA_REQUIR_STATUS</CommandText></Query><Fields><Field Name="POL_ID"><rd:TypeName>System.String</rd:TypeName><DataField>POL_ID</DataField></Field><Field Name="REQIR_ID"><rd:TypeName>System.String</rd:TypeName><DataField>REQIR_ID</DataField></Field><Field Name="ETBL_DESC_TXT"><rd:TypeName>System.String</rd:TypeName><DataField>ETBL_DESC_TXT</DataField></Field><Field Name="REASON"><rd:TypeName>System.String</rd:TypeName><DataField>REASON</DataField></Field><Field Name="CPREQ_STAT_CD"><rd:TypeName>System.String</rd:TypeName><DataField>CPREQ_STAT_CD</DataField></Field></Fields></DataSet><DataSet Name="FailedSTPCode"><Query><DataSourceName>STP</DataSourceName><CommandText>SELECT  
    r.application_number, 
    r.policy_number,
    STRING_AGG(rd.rule_code || ':' || rd.rule_result_code, ',') AS rule_codes
FROM 
    "result" r 
LEFT JOIN 
    result_detail rd 
    ON rd.result_id = r.id 
GROUP BY 
    r.application_number, 
    r.policy_number</CommandText></Query><Fields><Field Name="application_number"><rd:TypeName>System.String</rd:TypeName><DataField>application_number</DataField></Field><Field Name="policy_number"><rd:TypeName>System.String</rd:TypeName><DataField>policy_number</DataField></Field><Field Name="rule_codes"><rd:TypeName>System.String</rd:TypeName><DataField>rule_codes</DataField></Field></Fields></DataSet><DataSet Name="LoanInfo"><Query><DataSourceName>SALEPORTAL</DataSourceName><CommandText>WITH SimplifyLoan AS (
    SELECT
        policy_id = a.policy_id,
        loan_id = linfo.loan_number,
        loan_amount = linfo.loan_amount,
        outstanding_amount = linfo.outstanding_amount,
        name = CONCAT(lib.first_name, ' ', lib.last_name),
        role = CASE WHEN lib.policy_owner = 1 THEN 'PO' END,
        type = CASE lib.type
                    WHEN 'borrower' THEN 'Borrower'
                    WHEN 'co-borrower' THEN 'Co-Borrower'
               END
    FROM loan_information_borrower lib
    LEFT JOIN loan_information linfo ON linfo.id = lib.loan_id
    LEFT JOIN applications a ON a.quotation_id = linfo.quotation_id
    WHERE a.status = 'S'
        AND a.policy_id IS NOT NULL
        AND linfo.enable = 1
        AND lib.enable = 1
),

ManualBorrower AS (
    SELECT
        policy_id = a.policy_id,
        loan_id = lc.contract_number,
        loan_amount = lc.loan_amount,
        outstanding_amount = lc.outstanding_amount,
        name = CONCAT(c.last_name, ' ', c.first_name),
        role = 'PO',
        type = 'Borrower'
    FROM customers c
    INNER JOIN loan_contracts lc ON lc.application_id = c.application_id
    LEFT JOIN applications a ON a.id = c.application_id
    LEFT JOIN SimplifyLoan sl ON sl.policy_id = a.policy_id
    WHERE a.status = 'S'
        AND a.policy_id IS NOT NULL
        AND c.policy_owner = 1
        AND sl.policy_id IS NULL
),

ManualCoBorrower AS (
    SELECT
        policy_id = a.policy_id,
        loan_id = lc.contract_number,
        loan_amount = lc.loan_amount,
        outstanding_amount = lc.outstanding_amount,
        name = lc.co_borrower_name,
        role = NULL,
        type = 'Co-Borrower'
    FROM loan_contracts lc
    LEFT JOIN applications a ON a.id = lc.application_id
    LEFT JOIN SimplifyLoan sl ON sl.policy_id = a.policy_id
    WHERE a.status = 'S'
        AND a.policy_id IS NOT NULL
        AND lc.co_borrower_name IS NOT NULL
        AND lc.co_borrower_name &lt;&gt; ''
        AND sl.policy_id IS NULL
),

AllLoanMember AS (
    SELECT * FROM SimplifyLoan
    UNION ALL
    SELECT * FROM ManualBorrower
    UNION ALL
    SELECT * FROM ManualCoBorrower
)

SELECT
    alm.policy_id,
    loan_id = MAX(alm.loan_id),
    loan_amount = ABS(MAX(alm.loan_amount)),
    outstanding_amount = ABS(MAX(alm.outstanding_amount)),

    names =
        STUFF((
            SELECT CHAR(10) + alm2.name
            FROM AllLoanMember alm2
            WHERE alm2.policy_id = alm.policy_id
            ORDER BY CASE WHEN alm2.role = 'PO' THEN 0 ELSE 1 END, alm2.name
            FOR XML PATH(''), TYPE
        ).value('.', 'NVARCHAR(MAX)'), 1, 1, ''),

    po_loan_role = MAX(CASE WHEN alm.role = 'PO' THEN alm.type END)

FROM AllLoanMember alm
GROUP BY alm.policy_id
ORDER BY alm.policy_id;</CommandText></Query><Fields><Field Name="policy_id"><rd:TypeName>System.String</rd:TypeName><DataField>policy_id</DataField></Field><Field Name="loan_id"><rd:TypeName>System.String</rd:TypeName><DataField>loan_id</DataField></Field><Field Name="loan_amount"><rd:TypeName>System.Decimal</rd:TypeName><DataField>loan_amount</DataField></Field><Field Name="outstanding_amount"><rd:TypeName>System.Decimal</rd:TypeName><DataField>outstanding_amount</DataField></Field><Field Name="names"><rd:TypeName>System.String</rd:TypeName><DataField>names</DataField></Field><Field Name="po_loan_role"><rd:TypeName>System.String</rd:TypeName><DataField>po_loan_role</DataField></Field></Fields></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Tablix Name="Tablix1"><TablixBody><TablixColumns><TablixColumn><Width>0.4in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1.1in</Width></TablixColumn><TablixColumn><Width>1.8in</Width></TablixColumn><TablixColumn><Width>0.6in</Width></TablixColumn><TablixColumn><Width>1.1in</Width></TablixColumn><TablixColumn><Width>1.16667in</Width></TablixColumn><TablixColumn><Width>1.4in</Width></TablixColumn><TablixColumn><Width>1.1in</Width></TablixColumn><TablixColumn><Width>1.20833in</Width></TablixColumn><TablixColumn><Width>1.4in</Width></TablixColumn><TablixColumn><Width>1.1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1.4in</Width></TablixColumn><TablixColumn><Width>1.1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1.6in</Width></TablixColumn><TablixColumn><Width>1.3in</Width></TablixColumn><TablixColumn><Width>1.8in</Width></TablixColumn><TablixColumn><Width>2.2in</Width></TablixColumn><TablixColumn><Width>1.1in</Width></TablixColumn><TablixColumn><Width>1.3in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>0.9in</Width></TablixColumn