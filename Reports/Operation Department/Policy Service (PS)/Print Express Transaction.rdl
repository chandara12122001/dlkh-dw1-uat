<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df"><df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily><AutoRefresh>0</AutoRefresh><DataSources><DataSource Name="STAGE_PROD"><DataSourceReference>Datawarehouse77_STAGE</DataSourceReference><rd:SecurityType>None</rd:SecurityType><rd:DataSourceID>16ef2aad-5f87-4e66-becb-a2f907c9ca27</rd:DataSourceID></DataSource></DataSources><DataSets><DataSet Name="PXDetail"><Query><DataSourceName>STAGE_PROD</DataSourceName><QueryParameters><QueryParameter Name="@PolicyId"><Value>=Parameters!PolicyId.Value</Value></QueryParameter><QueryParameter Name="@DocumentId"><Value>=Parameters!DocumentId.Value</Value></QueryParameter><QueryParameter Name="@ValueFrom"><Value>=Parameters!ValueFrom.Value</Value></QueryParameter><QueryParameter Name="@ValueTo"><Value>=Parameters!ValueTo.Value</Value></QueryParameter></QueryParameters><CommandText>SELECT 
RTRIM(PX.POL_ID) AS POL_ID,
CONVERT(VARCHAR,POL.POL_INFC_DT,105) AS INFORCE_DATE,
CONCAT(RTRIM(CLI_NM.CLI_INDV_SUR_NM),' ',RTRIM(CLI_NM.CLI_INDV_GIV_NM)) AS PO_NAME,
CASE RTRIM(PX.DOC_ID)
	WHEN 'NOT-TAKEN-COMP' THEN 'NTU'
	WHEN 'NTU-CFI-SMS' THEN 'CFI'
	WHEN 'WLCML' THEN 'ISSUANCE'
	ELSE RTRIM(PX.DOC_ID)
END AS DOC_ID,
RTRIM(PH.CLI_CNTCT_ID_TXT) SMS,
CASE
	WHEN RIGHT(RTRIM(PX.DOC_ID),3)='SMS' THEN NULL
	ELSE RTRIM(EM.CLI_CNTCT_ID_TXT)
END AS MAIL,
CONVERT(VARCHAR,PX.TRNXT_TRXN_EFF_DT,105) AS SEND_DATE,
CONVERT(VARCHAR,PX.TRNXT_PRCES_DT,105) AS PROCESS_DATE,
PX.TRNXT_PRCES_TIME AS PROCESS_TIME,
CASE
 WHEN PX.TRNXT_PRT_STAT_CD='2' THEN 'SENT'
 ELSE 'PENDING'
END AS STATUS
FROM SGTM_PX PX
INNER JOIN SGTB_POLICY_CLIENT POLC ON PX.POL_ID=POLC.POL_ID AND POLC.POL_CLI_REL_TYP_CD='O'
INNER JOIN SGTB_POLICY POL ON POLC.POL_ID=POL.POL_ID
INNER JOIN DLKHDIM..DIM_CLIENT_IND CLI_NM ON POLC.CLI_ID=CLI_NM.CLI_ID AND CLI_NM.IS_CURRENT=1
LEFT JOIN SGTM_CLIENT_CONTACT PH ON POLC.CLI_ID=PH.CLI_ID AND PH.CLI_CNTCT_ID_CD='MO'
LEFT JOIN SGTM_CLIENT_CONTACT EM ON POLC.CLI_ID=EM.CLI_ID AND EM.CLI_CNTCT_ID_CD='EM'
WHERE PX.POL_ID = (CASE WHEN @PolicyId='' OR @PolicyId IS NULL THEN PX.POL_ID ELSE @PolicyId END)
AND PX.DOC_ID = (CASE WHEN @DocumentId='' OR @DocumentId IS NULL THEN PX.DOC_ID ELSE @DocumentId END)
AND DATEDIFF(DAY,PX.TRNXT_PRCES_DT,(CASE WHEN @ValueFrom='' OR @ValueFrom IS NULL THEN '1980-01-01' ELSE @ValueFrom END))&lt;=0
AND DATEDIFF(DAY,PX.TRNXT_PRCES_DT,(CASE WHEN @ValueTo='' OR @ValueTo IS NULL THEN '2060-01-01' ELSE @ValueTo END))&gt;=0
AND RTRIM(PX.DOC_ID) NOT IN ('COVER','ACKNOWLEDGE','INS-CERT')
ORDER BY PX.POL_ID,PX.TRNXT_PRCES_DT</CommandText></Query><Fields><Field Name="POL_ID"><DataField>POL_ID</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="INFORCE_DATE"><DataField>INFORCE_DATE</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="PO_NAME"><DataField>PO_NAME</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="DOC_ID"><DataField>DOC_ID</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="SMS"><DataField>SMS</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="MAIL"><DataField>MAIL</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="SEND_DATE"><DataField>SEND_DATE</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="PROCESS_DATE"><DataField>PROCESS_DATE</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="PROCESS_TIME"><DataField>PROCESS_TIME</DataField><rd:TypeName>System.TimeSpan</rd:TypeName></Field><Field Name="STATUS"><DataField>STATUS</DataField><rd:TypeName>System.String</rd:TypeName></Field></Fields></DataSet><DataSet Name="DOCTYPE"><Query><DataSourceName>STAGE_PROD</DataSourceName><CommandText>SELECT NULL AS DOC_ID, 'All Document' AS DOC_TYPE
UNION
SELECT distinct RTRIM(PX.DOC_ID) AS DOC_ID, 
CASE RTRIM(PX.DOC_ID)
	WHEN 'NOT-TAKEN-COMP' THEN 'NTU'
	WHEN 'NTU-CFI-SMS' THEN 'CFI'
	WHEN 'WLCML' THEN 'ISSUANCE'
	ELSE RTRIM(PX.DOC_ID)
END AS DOC_TYPE
FROM SGTM_PX PX
WHERE RTRIM(PX.DOC_ID) NOT IN ('COVER','ACKNOWLEDGE','INS-CERT')</CommandText></Query><Fields><Field Name="DOC_ID"><DataField>DOC_ID</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="DOC_TYPE"><DataField>DOC_TYPE</DataField><rd:TypeName>System.String</rd:TypeName></Field></Fields></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Tablix Name="Tablix1"><TablixBody><TablixColumns><TablixColumn><Width>2in</Width></TablixColumn><TablixColumn><Width>2in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>3in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn></TablixColumns><TablixRows><TablixRow><Height>0.25in</Height><TablixCells><TablixCell><CellContents><Textbox Name="Textbox35"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>Print Express Report</Value><Style><FontFamily>Arial</FontFamily><FontSize>12pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><rd:DefaultName>Textbox35</rd:DefaultName><Style><Border><Color>LightGrey</Color><Style>None</Style></Border><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox><ColSpan>9</ColSpan></CellContents></TablixCell><TablixCell /><TablixCell /><TablixCell /><TablixCell /><TablixCell /><TablixCell /><TablixCell /><TablixCell /></TablixCells></TablixRow><TablixRow><Height>0.25in</Height><TablixCells><TablixCell><CellContents><Textbox Name="Textbox27"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Label>Transaction Date</Label><Value>=Format(Parameters!ValueFrom.Val