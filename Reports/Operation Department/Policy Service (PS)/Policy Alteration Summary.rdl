<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df"><df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily><AutoRefresh>0</AutoRefresh><DataSources><DataSource Name="DataSource3"><DataSourceReference>/Policy Alteration/Alteration Data Source</DataSourceReference><rd:SecurityType>DataBase</rd:SecurityType><rd:DataSourceID>d73cbfbe-1a93-44d8-8d27-22c4a20cafe1</rd:DataSourceID></DataSource></DataSources><DataSets><DataSet Name="DataSet1"><Query><DataSourceName>DataSource3</DataSourceName><QueryParameters><QueryParameter Name="@FromDate"><Value>=Parameters!FromDate.Value</Value><rd:UserDefined>true</rd:UserDefined></QueryParameter><QueryParameter Name="@ToDate"><Value>=Parameters!ToDate.Value</Value><rd:UserDefined>true</rd:UserDefined></QueryParameter></QueryParameters><CommandText>SELECT D.title as MAIN_REQUEST
	,(SELECT COUNT(*) FROM request_alteration where request_type= D.title AND request_alteration.case_received_date BETWEEN @FromDate AND @ToDate ) as NO_CASE
	,(SELECT COUNT(*) FROM request_alteration where request_type= D.title AND request_status = 'Complete' AND request_alteration.case_received_date BETWEEN @FromDate AND @ToDate ) as COMPLETE
	,(SELECT COUNT(*) FROM request_alteration where request_type= D.title AND request_status = 'Pending' AND request_alteration.case_received_date BETWEEN @FromDate AND @ToDate) as PENDING
	,(SELECT COUNT(*) FROM request_alteration where request_type= D.title AND request_status = 'Waiting' AND request_alteration.case_received_date BETWEEN @FromDate AND @ToDate) as WAITING
	,(SELECT COUNT(*) FROM request_alteration where request_type= D.title AND request_status = 'Cancel' AND request_alteration.case_received_date BETWEEN @FromDate AND @ToDate) as CANCEL
	,(SELECT COUNT(*) FROM request_alteration where request_type= D.title AND request_status = 'Reject' AND request_alteration.case_received_date BETWEEN @FromDate AND @ToDate) as REJECT
FROM dropdown_setup D
WHERE type_value = 'al request type'</CommandText></Query><Fields><Field Name="MAIN_REQUEST"><DataField>MAIN_REQUEST</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="NO_CASE"><DataField>NO_CASE</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="COMPLETE"><DataField>COMPLETE</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="PENDING"><DataField>PENDING</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="WAITING"><DataField>WAITING</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="CANCEL"><DataField>CANCEL</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="REJECT"><DataField>REJECT</DataField><rd:TypeName>System.Int32</rd:TypeName></Field></Fields></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Tablix Name="Tablix1"><TablixBody><TablixColumns><TablixColumn><Width>2.25334in</Width></TablixColumn><TablixColumn><Width>1.3875in</Width></TablixColumn><TablixColumn><Width>1.42917in</Width></TablixColumn><TablixColumn><Width>1.42917in</Width></TablixColumn><TablixColumn><Width>1.42917in</Width></TablixColumn><TablixColumn><Width>1.42917in</Width></TablixColumn><TablixColumn><Width>1.42917in</Width></TablixColumn></TablixColumns><TablixRows><TablixRow><Height>0.27083in</Height><TablixCells><TablixCell><CellContents><Textbox Name="Textbox3"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>Main Subject Request</Value><Style><Color>White</Color></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs><rd:DefaultName>Textbox3</rd:DefaultName><Style><Border><Color>LightGrey</Color><Style>Solid</Style></Border><BackgroundColor>Chocolate</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell><TablixCell><CellCon