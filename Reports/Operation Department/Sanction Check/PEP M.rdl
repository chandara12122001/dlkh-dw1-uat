<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner"><AutoRefresh>0</AutoRefresh><DataSources><DataSource Name="DataSet1"><ConnectionProperties><DataProvider>SQL</DataProvider><ConnectString>Data Source=10.116.18.12;Initial Catalog=dbsanction</ConnectString><Prompt>Specify a user name and password for data source DataSet1:</Prompt></ConnectionProperties><rd:SecurityType>DataBase</rd:SecurityType><rd:DataSourceID>8dfbb0f9-7268-475a-946d-43d99dfaaec8</rd:DataSourceID></DataSource></DataSources><DataSets><DataSet Name="DataSet1"><Query><DataSourceName>DataSet1</DataSourceName><CommandText>	SELECT ROW_NUMBER() OVER ( ORDER BY Pep_Name ASC ) Pep_ID,Pep_Name,P.Pep_Appointment_Date, Pep_Sex,Pep_POS,Pep_Insti,Pep_DOB,Client_ING,Client_KH,IsApproved,Approved_By,Approved_Date,
		Total = (SELECT COUNT(POL_ID) FROM OPENQUERY(PROD7,  'SELECT POL_ID FROM KCAPXPR1.TPOL P WHERE P.POL_CSTAT_CD in (''1'',''B'')')),
		C.[Document_Date]
	FROM TKHCLIENT C LEFT JOIN TPEP P ON C.Client_KH=P.Pep_Name COLLATE Latin1_General_BIN2
	INNER JOIN (
		SELECT CLI_ID FROM OPENQUERY(PROD7, 'SELECT CLI_ID FROM KCAPXPR1.TPOLC C INNER JOIN KCAPXPR1.TPOL P ON C.POL_ID=P.POL_ID GROUP BY CLI_ID')
	) CLI ON CLI.CLI_ID = Client_ING</CommandText></Query><Fields><Field Name="Pep_ID"><DataField>Pep_ID</DataField><rd:TypeName>System.Int64</rd:TypeName></Field><Field Name="Pep_Name"><DataField>Pep_Name</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="Pep_Appointment_Date"><DataField>Pep_Appointment_Date</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="Pep_Sex"><DataField>Pep_Sex</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="Pep_POS"><DataField>Pep_POS</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="Pep_Insti"><DataField>Pep_Insti</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="Pep_DOB"><DataField>Pep_DOB</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="Client_ING"><DataField>Client_ING</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="Client_KH"><DataField>Client_KH</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="Total"><DataField>Total</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="IsApproved"><DataField>IsApproved</DataField><rd:TypeName>System.Boolean</rd:TypeName></Field><Field Name="Approved_By"><DataField>Approved_By</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="Approved_Date"><DataField>Approved_Date</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field><Field Name="Document_Date"><DataField>Document_Date</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field></Fields><rd:DataSetInfo><rd:DataSetName>DataSet1</rd:DataSetName><rd:SchemaPath>C:\work\DLKH_Sys\SC\SC\SC\Reports\DataSet1.xsd</rd:SchemaPath><rd:TableName>dtPep</rd:TableName><rd:TableAdapterFillMethod /><rd:TableAdapterGetDataMethod /><rd:TableAdapterName /></rd:DataSetInfo></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Tablix Name="Tablix1"><TablixBody><TablixColumns><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn>