ultValue><DataSetReference><DataSetName>DataSet2</DataSetName><ValueField>title</ValueField></DataSetReference></DefaultValue><Prompt>Main Subject</Prompt><ValidValues><DataSetReference><DataSetName>DataSet2</DataSetName><ValueField>title</ValueField><LabelField>title</LabelField></DataSetReference></ValidValues></ReportParameter></ReportParameters><ReportParametersLayout><GridLayoutDefinition><NumberOfColumns>4</NumberOfColumns><NumberOfRows>2</NumberOfRows><CellDefinitions><CellDefinition><ColumnIndex>0</ColumnIndex><RowIndex>0</RowIndex><ParameterName>FromDate</ParameterName></CellDefinition><CellDefinition><ColumnIndex>1</ColumnIndex><RowIndex>0</RowIndex><ParameterName>ToDate</ParameterName></CellDefinition><CellDefinition><ColumnIndex>2</ColumnIndex><RowIndex>0</RowIndex><ParameterName>RequestType</ParameterName></CellDefinition></CellDefinitions></GridLayoutDefinition></ReportParametersLayout><Code>Public Function StripHTML(ByVal sInput As String) As String
IF sInput IsNot Nothing Then 
IF(sInput &lt;&gt;"") Then
Dim objRegExp AS NEW System.Text.RegularExpressions.Regex("&lt;(.|\n)+?&gt;") 

sInput = Replace(sInput, "&lt;BR&gt;", Chr(10))
sInput = Replace(sInput, "&lt;br&gt;", Chr(10))
sInput = Replace(sInput, "&lt;br/&gt;", Chr(10))
sInput = Replace(sInput,"&amp;#160;", " ") 
sInput = Replace(sInput, "&lt;li&gt;", "-")
sInput = Replace(sInput, "&amp;ndash;", "-")
sInput = Replace(sInput, "&amp;mdash;", "-")
sInput = Replace(sInput, "&amp;iexcl;", "ˇ")
sInput = Replace(sInput, "&amp;iquest;", "ż")
sInput = Replace(sInput, "&amp;amp;quot;", "")

sInput = Replace(sInput, "&amp;lsquo;", "‘")
sInput = Replace(sInput, "&amp;rsquo;", "’")
sInput = Replace(sInput, "&amp;laquo;", "«")
sInput = Replace(sInput, "&amp;raquo;", "»")
sInput = Replace(sInput, "&amp;nbsp;", " ")
sInput = Replace(sInput, "&amp;amp;", "&amp;")
sInput = Replace(sInput, "&amp;cent;", "˘")
sInput = Replace(sInput, "&amp;copy;", "©")
sInput = Replace(sInput, "&amp;divide;", "÷")
sInput = Replace(sInput, "&amp;gt;", "&gt;")
sInput = Replace(sInput, "&amp;lt;", "&lt;")
sInput = Replace(sInput, "&amp;micro;", "µ")
sInput = Replace(sInput, "&amp;middot;", "·")
sInput = Replace(sInput, "&amp;para;", "¶")
sInput = Replace(sInput, "&amp;plusmn;", "±")
sInput = Replace(sInput, "&amp;euro;", "€")
sInput = Replace(sInput, "&amp;pound;", "Ł")
sInput = Replace(sInput, "&amp;reg;", "®")
sInput = Replace(sInput, "&amp;sect;", "§")
sInput = Replace(sInput, "&amp;trade;", "™")
sInput = Replace(sInput, "&amp;yen;", "Ą")
sInput = Replace(sInput, "&amp;aacute;", "á")
sInput = Replace(sInput, "&amp;Aacute;", "Á")
sInput = Replace(sInput, "&amp;agrave;", "ŕ")
sInput = Replace(sInput, "&amp;Agrave;", "Ŕ")
sInput = Replace(sInput, "&amp;acirc;", "â")
sInput = Replace(sInput, "&amp;Acirc;", "Â")
sInput = Replace(sInput, "&amp;aring;", "ĺ")
sInput = Replace(sInput, "&amp;Aring;", "Ĺ")
sInput = Replace(sInput, "&amp;atilde;", "ă")
sInput = Replace(sInput, "&amp;Atilde;", "Ă")
sInput = Replace(sInput, "&amp;auml;", "ä")
sInput = Replace(sInput, "&amp;Auml;", "Ä")
sInput = Replace(sInput, "&amp;aelig;", "ć")
sInput = Replace(sInput, "&amp;AElig;", "Ć")
sInput = Replace(sInput, "&amp;ccedil;", "ç")
sInput = Replace(sInput, "&amp;Ccedil;", "Ç")
sInput = Replace(sInput, "&amp;eacute;", "é")
sInput = Replace(sInput, "&amp;Eacute;", "É")
sInput = Replace(sInput, "&amp;egrave;", "č")
