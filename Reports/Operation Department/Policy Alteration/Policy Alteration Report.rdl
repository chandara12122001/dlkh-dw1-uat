sInput = Replace(sInput, "&amp;ograve;", "ň")
sInput = Replace(sInput, "&amp;Ograve;", "Ň")
sInput = Replace(sInput, "&amp;ocirc;", "ô")
sInput = Replace(sInput, "&amp;Ocirc;", "Ô")
sInput = Replace(sInput, "&amp;oslash;", "ř")
sInput = Replace(sInput, "&amp;Oslash;", "Ř")
sInput = Replace(sInput, "&amp;otilde;", "ő")
