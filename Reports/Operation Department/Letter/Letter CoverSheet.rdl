ID_TXT"><DataField>CLI_CNTCT_ID_TXT</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="CLI_ADDR_LN_1_TXT"><DataField>CLI_ADDR_LN_1_TXT</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="COMMUNE"><DataField>COMMUNE</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="DISTRICT"><DataField>DISTRICT</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="CITY"><DataField>CITY</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="TYPE"><DataField>TYPE</DataField><rd:TypeName>System.String</rd:TypeName></Field></Fields></DataSet><DataSet Name="ME_INFO"><Query><DataSourceName>SALEPORTAL_PROD</DataSourceName><QueryParameters><QueryParameter Name="@PolID"><Value>=Parameters!PolID.Value</Value></QueryParameter></QueryParameters><CommandText>
SELECT AP.policy_id
,AP.number
,RTRIM(PC.name) hosp_name
,RTRIM(MI.appointment_date) appointment_date
,RTRIM(MI.appointment_time) appointment_time
FROM applications AP
LEFT JOIN medical_invitations MI ON MI.application_id = AP.id
LEFT JOIN pannel_clinics PC ON PC.id = MI.panel_clinic_id AND PC.enable = 1
WHERE AP.number IS NOT NULL AND AP.policy_id = @PolID</CommandText></Query><Fields><Field Name="policy_id"><DataField>policy_id</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="number"><DataField>number</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="hosp_name"><DataField>hosp_name</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="appointment_date"><DataField>appointment_date</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="appointment_time"><DataField>appointment_time</DataField><rd:TypeName>System.String</rd:TypeName></Field></Fields></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Tablix Name="Tablix2"><TablixBody><TablixColumns><TablixColumn><Width>0.35in</Width></TablixColumn><TablixColumn><Width>0.35in</Width></TablixColumn><TablixColumn><Width>0.20437in</Width></TablixColumn><TablixColumn><Width>0.49563in</Width></TablixColumn><TablixColumn><Width>0.8in</Width></TablixColumn><TablixColumn><Width>0.67896in</Width></TablixColumn><TablixColumn><Width>0.12104in</Width></TablixColumn><TablixColumn><Width>0.42062in</Width></TablixColumn><TablixColumn><Width>0.37938in</Width></TablixColumn><TablixColumn><Width>0.46875in</Width></TablixColumn><TablixColumn><Width>0.13125in</Width></TablixColumn><TablixColumn><Width>0.6in</Width></TablixColumn><TablixColumn><Width>0.7in</Width></TablixColumn><TablixColumn><Width>0.04562in</Width></TablixColumn><TablixColumn><Width>0.45438in</Width></TablixColumn><TablixColumn><Width>0.7in</Width></TablixColumn><TablixColumn><Width>0.82in</Width></TablixColumn></TablixColumns><TablixRows><TablixRow><Height>0.03125in</Height><TablixCells><TablixCell><CellContents><Textbox Name="Textbox92"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value /><Style><FontFamily>dubai</FontFamily><FontSize>8pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style /></Pa