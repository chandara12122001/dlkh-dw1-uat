<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df"><df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily><AutoRefresh>0</AutoRefresh><DataSources><DataSource Name="Dataware_House"><DataSourceReference>FACT_PROD</DataSourceReference><rd:SecurityType>None</rd:SecurityType><rd:DataSourceID>dd3b3f28-3b99-414c-9340-f32ef29f534a</rd:DataSourceID></DataSource></DataSources><DataSets><DataSet Name="POL_INFO"><Query><DataSourceName>Dataware_House</DataSourceName><QueryParameters><QueryParameter Name="@ValueDate"><Value>=Parameters!ValueDate.Value</Value></QueryParameter><QueryParameter Name="@POL_ID"><Value>=Parameters!PolicyId.Value</Value></QueryParameter></QueryParameters><CommandText>SELECT 
REPLACE(CONVERT(VARCHAR,GETDATE(),106),' ','/') AS GEN_DATE,
REPLACE(CONVERT(VARCHAR,@ValueDate,106),' ','/') AS REPORT_DATE,
CVG.PLAN_ID,
CASE
	WHEN CLI.CLI_SEX_CD='M' THEN 'Mr'
	WHEN CLI.CLI_SEX_CD='F' THEN 'Ms'
	ELSE ''
END AS CLI_TITLE,
CONCAT(RTRIM(NM.ENTR_SUR_NM),' ',RTRIM(NM.ENTR_GIV_NM)) AS PO_NAME,
PLA.ETBL_DESC_TXT AS BASE_PLAN,
--LEFT(RTRIM(PLA.ETBL_DESC_TXT),CHARINDEX('*',RTRIM(PLA.ETBL_DESC_TXT))-1) AS BASE_PLAN,
RTRIM(POL.POL_MPREM_AMT) AS PREM_AMOUNT,
RTRIM(POL.POL_ID) AS POL_ID,
RTRIM(BILL.DM_AV_DESC_TXT) AS BILL_MODE,
RTRIM(STAT.DM_AV_DESC_TXT) AS POL_STATUS,
REPLACE(CONVERT(VARCHAR,POL.POL_ISS_EFF_DT,106),' ','/') AS COM_DATE,
RTRIM(CVG.CVG_FACE_AMT) AS MAT_BEN,
REPLACE(CONVERT(VARCHAR,CVG.CVG_MAT_XPRY_DT,106),' ','/') AS MAT_DATE,
CASE
	WHEN LI.CLI_SEX_CD='M' THEN 'Mr'
	WHEN LI.CLI_SEX_CD='F' THEN 'Ms'
	ELSE ''
END AS LI_TITLE,
CONCAT(RTRIM(CVG_NM.ENTR_SUR_NM),' ',RTRIM(CVG_NM.ENTR_GIV_NM)) AS LI_NAME,
RTRIM(CVG.CVG_FACE_AMT) AS SUM_INSUR,
RTRIM(CVG_STAT.DM_AV_DESC_TXT) AS CVG_STATUS
FROM DLKHFACT..FACT_POL_ISSUSED FACT
INNER JOIN DLKHDIM..DIM_POLICY POL ON FACT.POL_KEY=POL.POL_KEY
INNER JOIN DLKHDIM..DIM_POLICY_CLIENT POL_CLI ON POL.POL_ID=POL_CLI.POL_ID AND POL_CLI.POL_CLI_REL_SUB_CD='P' AND POL_CLI.IS_CURRENT=1
INNER JOIN DLKHDIM..DIM_CLIENT CLI ON POL_CLI.CLI_ID=CLI.CLI_ID AND CLI.IS_CURRENT=1
INNER JOIN DLKHDIM..DIM_CLIENT_IND NM ON POL_CLI.CLI_ID=NM.CLI_ID AND NM.IS_CURRENT=1
INNER JOIN DLKHDIM..DIM_COVERAGE CVG ON FACT.COV_KEY=CVG.COV_KEY AND CVG.CVG_NUM='01'
INNER JOIN DLKHSTAGE..SGTB_COVERAGE_CLI CVG_CLI ON POL.POL_ID=CVG_CLI.POL_ID AND CVG.CVG_NUM=CVG_CLI.CVG_NUM
INNER JOIN DLKHDIM..DIM_CLIENT LI ON CVG_CLI.INSRD_CLI_ID=LI.CLI_ID AND LI.IS_CURRENT=1
INNER JOIN DLKHDIM..DIM_CLIENT_IND CVG_NM ON CVG_CLI.INSRD_CLI_ID=CVG_NM.CLI_ID AND CVG_NM.IS_CURRENT=1
LEFT JOIN DLKHSTAGE..SGTB_EDITTABLE PLA ON POL.PLAN_ID=PLA.ETBL_VALU_ID AND PLA.ETBL_TYP_ID='PLAN' AND PLA.ETBL_LANG_CD='E' AND POL.CO_ID='CP'
LEFT JOIN DLKHSTAGE..SGTM_PARA_1 STAT ON POL.POL_CSTAT_CD=STAT.DM_AV_CD AND STAT.DM_AV_TBL_CD='POL-CSTAT-CD' AND STAT.DM_AV_DESC_LANG_CD='E' AND STAT.CO_ID='CP'
LEFT JOIN DLKHSTAGE..SGTM_PARA_1 BILL ON POL.POL_BILL_MODE_CD=BILL.DM_AV_CD AND BILL.DM_AV_TBL_CD='BILLN-MODE-CD' AND BILL.DM_AV_DESC_LANG_CD='E' AND BILL.CO_ID='CP'
LEFT JOIN DLKHSTAGE..SGTM_PARA_1 CVG_STAT ON CVG.CVG_CSTAT_CD=CVG_STAT.DM_AV_CD AND CVG_STAT.DM_AV_TBL_CD='CVG-CSTAT-CD' AND CVG_STAT.DM_AV_DESC_LANG_CD='E' AND CVG_STAT.CO_ID='CP'
WHERE FACT.DATE_KEY=CONVERT(VARCHAR,@ValueDate,112)
AND POL.POL_ID=@POL_ID</CommandText></Query><Fields><Field Name="GEN_DATE"><DataField>GEN_DATE</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="REPORT_DATE"><DataField>REPORT_DATE</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="PLAN_ID"><DataField>PLAN_ID</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="CLI_TITLE"><DataField>CLI_TITLE</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="PO_NAME"><DataField>PO_NAME</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="BASE_PLAN"><DataField>BASE_PLAN</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="PREM_AMOUNT"><DataField>PREM_AMOUNT</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="POL_ID"><DataField>POL_ID</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="BILL_MODE"><DataField>BILL_MODE</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="POL_STATUS"><DataField>POL_STATUS</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="COM_DATE"><DataField>COM_DATE</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="MAT_BEN"><DataField>MAT_BEN</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="MAT_DATE"><DataField>MAT_DATE</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="LI_TITLE"><DataField>LI_TITLE</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="LI_NAME"><DataField>LI_NAME</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="SUM_INSUR"><DataField>SUM_INSUR</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="CVG_STATUS"><DataField>CVG_STATUS</DataField><rd:TypeName>System.String</rd:TypeName></Field></Fields></DataSet><DataSet Name="COVERAGE_INFO"><Query><DataSourceName>Dataware_House</DataSourceName><QueryParameters><QueryParameter Name="@POL_ID"><Value>=Parameters!PolicyId.Value</Value></QueryParameter><QueryParameter Name="@ValueDate"><Value>=Parameters!ValueDate.Value</Value></QueryParameter></QueryParameters><CommandText>SELECT 
CVG_CLI.INSRD_CLI_ID,
CASE
	WHEN LI.CLI_SEX_CD='M' THEN 'Mr'
	WHEN LI.CLI_SEX_CD='F' THEN 'Ms'
	ELSE ''
END AS LI_TITLE,
CASE
	WHEN POL_CLI.CLI_ID=CVG_CLI.INSRD_CLI_ID THEN 'Policy Owner'
	ELSE 'Life Insured'
END AS RIDER_TYPE_EN,
CASE
	WHEN POL_CLI.CLI_ID=CVG_CLI.INSRD_CLI_ID THEN N'??????????????????????'
	ELSE N'???????????????????????'
END AS RIDER_TYPE_KH,
CONCAT(RTRIM(CVG_NM.ENTR_SUR_NM),' ',RTRIM(CVG_NM.ENTR_GIV_NM)) AS LI_NAME,
CVG.PLAN_ID,
CASE
	WHEN CVG.PLAN_ID='TLFI01' THEN N'??????????????????'
	WHEN CVG.PLAN_ID='TLFP01' THEN N'???????????????????'
	WHEN CVG.PLAN_ID='WP00R1' THEN N'????????????????????????????????'
	ELSE RTRIM(PLA.ETBL_DESC_TXT)
END AS CVG_PLAN_KH,
--RTRIM(PLA.ETBL_DESC_TXT) AS CVG_PLAN_EN,
LEFT(PLA.ETBL_DESC_TXT,CHARINDEX('*',PLA.ETBL_DESC_TXT)-1) CVG_PLAN_EN,
CVG.CVG_FACE_AMT,
RTRIM(CVG_STAT.DM_AV_DESC_TXT) AS CVG_STATUS
FROM DLKHFACT..FACT_POL_ISSUSED FACT
INNER JOIN DLKHDIM..DIM_POLICY POL ON FACT.POL_KEY=POL.POL_KEY
INNER JOIN DLKHDIM..DIM_POLICY_CLIENT POL_CLI ON POL.POL_ID=POL_CLI.POL_ID AND POL_CLI.POL_CLI_REL_SUB_CD='P' AND POL_CLI.IS_CURRENT=1
INNER JOIN DLKHDIM..DIM_COVERAGE CVG ON FACT.COV_KEY=CVG.COV_KEY AND POL.PLAN_ID&lt;&gt;CVG.PLAN_ID
INNER JOIN DLKHSTAGE..SGTB_COVERAGE_CLI CVG_CLI ON POL.POL_ID=CVG_CLI.POL_ID AND CVG.CVG_NUM=CVG_CLI.CVG_NUM
INNER JOIN DLKHDIM..DIM_CLIENT LI ON CVG_CLI.INSRD_CLI_ID=LI.CLI_ID AND LI.IS_CURRENT=1
INNER JOIN DLKHDIM..DIM_CLIENT_IND CVG_NM ON CVG_CLI.INSRD_CLI_ID=CVG_NM.CLI_ID AND CVG_NM.IS_CURRENT=1
LEFT JOIN DLKHSTAGE..SGTM_PARA_1 CVG_STAT ON CVG.CVG_CSTAT_CD=CVG_STAT.DM_AV_CD AND CVG_STAT.DM_AV_TBL_CD='CVG-CSTAT-CD' AND CVG_STAT.DM_AV_DESC_LANG_CD='E' AND CVG_STAT.CO_ID='CP'
LEFT JOIN DLKHSTAGE..SGTB_EDITTABLE PLA ON CVG.PLAN_ID=PLA.ETBL_VALU_ID AND PLA.ETBL_TYP_ID='PLAN' AND PLA.ETBL_LANG_CD='E' AND POL.CO_ID='CP'
WHERE POL.POL_ID=@POL_ID
AND FACT.DATE_KEY=CONVERT(VARCHAR,@ValueDate,112)
ORDER BY CVG_CLI.INSRD_CLI_ID</CommandText></Query><Fields><Field Name="INSRD_CLI_ID"><DataField>INSRD_CLI_ID</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="LI_TITLE"><DataField>LI_TITLE</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="RIDER_TYPE_EN"><DataField>RIDER_TYPE_EN</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="RIDER_TYPE_KH"><DataField>RIDER_TYPE_KH</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="LI_NAME"><DataField>LI_NAME</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="PLAN_ID"><DataField>PLAN_ID</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="CVG_PLAN_KH"><DataField>CVG_PLAN_KH</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="CVG_PLAN_EN"><DataField>CVG_PLAN_EN</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="CVG_FACE_AMT"><DataField>CVG_FACE_AMT</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field><Field Name="CVG_STATUS"><DataField>CVG_STATUS</DataField><rd:TypeName>System.String</rd:TypeName></Field></Fields></DataSet><DataSet Name="BENEFICIARY_INFO"><Query><DataSourceName>Dataware_House</DataSourceName><QueryParameters><QueryParameter Name="@ValueDate"><Value>=Parameters!ValueDate.Value</Value></QueryParameter><QueryParameter Name="@POL_ID"><Value>=Parameters!PolicyId.Value</Value></QueryParameter></QueryParameters><CommandText>SELECT
ROW_NUMBER() OVER(ORDER BY BEN.BNFY_SEQ_NUM) AS ROW_NUM,
BEN.BNFY_NM AS BEN_NAME
FROM DLKHDIM..DIM_BENE BEN
--INNER JOIN DLKHDIM..DIM_CLIENT_IND NM ON BEN.CLI_ID=NM.CLI_ID AND NM.IS_CURRENT=1
WHERE DATEDIFF(DAY,BEN.START_DT,@ValueDate)&gt;0 
AND BEN.BENE_KEY=DLKHDIM.dbo.BenKeyAtDate(BEN.POL_ID,BEN.BNFY_SEQ_NUM,@ValueDate)
AND BEN.POL_ID=@POL_ID</CommandText></Query><Fields><Field Name="ROW_NUM"><DataField>ROW_NUM</DataField><rd:TypeName>System.Int64</rd:TypeName></Field><Field Name="BEN_NAME"><DataField>BEN_NAME</DataField><rd:TypeName>System.String</rd:TypeName></Field></Fields></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Tablix Name="Tablix1"><TablixBody><TablixColumns><TablixColumn><Width>8.965cm</Width></TablixColumn><TablixColumn><Width>8.855cm</Width></TablixColumn></TablixColumns><TablixRows><TablixRow><Height>0.38681in</Height><TablixCells><TablixCell><CellContents><Textbox Name="Textbox183"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>???????????????????????????????</Value><Style><FontStyle>Normal</FontStyle><FontFamily>KH Siemreap</FontFamily><FontSize>14pt</FontSize><FontWeight>Bold</FontWeight><TextDecoration>Underline</TextDecoration><Color>#000000</Color></Style></TextRun><TextRun><Value>???????</Value><Style><FontStyle>Normal</FontStyle><FontFamily>Khmer OS Siemreap</FontFamily><FontSize>14pt</FontSize><FontWeight>Bold</FontWeight><TextDecoration>Underline</TextDecoration><Color>#000000</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><rd:DefaultName>Textbox183</rd:DefaultName><Style><Border><Style>None</Style></Border><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox><ColSpan>2</ColSpan></CellContents></TablixCell><TablixCell /></TablixCells></TablixRow><TablixRow><Height>0.25in</Height><TablixCells><TablixCell><CellContents><Textbox Name="Textbox102"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>Annual Policy Statement</Value><Style><FontStyle>Normal</FontStyle><FontFamily>Arial</FontFamily><FontWeight>Bold</FontWeight><TextDecoration>Underline</TextDecoration><Color>#595959</Co