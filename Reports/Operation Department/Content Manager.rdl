<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df"><df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily><AutoRefresh>0</AutoRefresh><DataSources><DataSource Name="CM_UAT"><ConnectionProperties><DataProvider>SQL</DataProvider><ConnectString>Data Source=10.116.17.206;Initial Catalog=CM_UAT</ConnectString><IntegratedSecurity>true</IntegratedSecurity></ConnectionProperties><rd:SecurityType>Integrated</rd:SecurityType><rd:DataSourceID>0b68c12f-bafc-4473-86f6-f5d1d1ccc555</rd:DataSourceID></DataSource><DataSource Name="DLIUDW01"><ConnectionProperties><DataProvider>SQL</DataProvider><ConnectString>Data Source=DLIUDW01;Initial Catalog=DLKHSTAGE</ConnectString><IntegratedSecurity>true</IntegratedSecurity></ConnectionProperties><rd:SecurityType>Integrated</rd:SecurityType><rd:DataSourceID>e8b2b391-ada6-43ad-86fc-90c273a120d5</rd:DataSourceID></DataSource></DataSources><DataSets><DataSet Name="DataSet1"><Query><DataSourceName>CM_UAT</DataSourceName><QueryParameters><QueryParameter Name="@START_DT"><Value>=Parameters!START_DT.Value</Value></QueryParameter><QueryParameter Name="@END_DT"><Value>=Parameters!END_DT.Value</Value></QueryParameter></QueryParameters><CommandText>SELECT 
policy_id = RTRIM(POL.policy_id),
APP_NO =POL.application_number,
Sub_DT = PD.created_at,
First_UPD = DF.created_at,
Last_UPD = DF.updated_at,
Del_User = (US.first_name + ' ' +US.last_name),
Del_File = DC.name,
Del_DT = DF.deleted_at,
SAC.TOTAL_DOC Sec_chek,
CVS.TOTAL_DOC Cover_sheet,
CFL.TOTAL_DOC CFI_Letter

FROM policies POL 
LEFT JOIN (SELECT ROW_NUMBER() OVER ( PARTITION BY policy_id ORDER BY created_at) AS ROW#1,*  FROM document_files) DF ON DF.policy_id = POL.id AND ROW#1 = 1
LEFT JOIN (SELECT ROW_NUMBER() OVER ( PARTITION BY policy_id ORDER BY created_at) AS ROW#,*  FROM policy_details) PD  ON PD.policy_id = POL.id and ROW# =1
LEFT JOIN users US ON US.id = DF.deleted_by
LEFT JOIN documents DC ON DC.id = DF.document_id 
LEFT JOIN (select policy_id, COUNT(document_id) TOTAL_DOC from document_files where  document_id = 11 GROUP BY policy_id) SAC ON SAC.policy_id = POL.id
LEFT JOIN (select policy_id, COUNT(document_id) TOTAL_DOC from document_files where  document_id = 13 GROUP BY policy_id) CVS ON CVS.policy_id = POL.id
LEFT JOIN (select policy_id, COUNT(document_id) TOTAL_DOC from document_files where  document_id = 19 GROUP BY policy_id) CFL  ON CFL.policy_id = POL.id

WHERE DF.created_at BETWEEN @START_DT AND @END_DT

ORDER BY POL.policy_id</CommandText></Query><Fields><Field Name="policy_id"><DataField>policy_id</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="APP_NO"><DataField>APP_NO</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="Sub_DT"><DataField>Sub_DT</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field><Field Name="First_UPD"><DataField>First_UPD</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field><Field Name="Last_UPD"><DataField>Last_UPD</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field><Field Name="Del_User"><DataField>Del_User</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="Del_File"><DataField>Del_File</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="Del_DT"><DataField>Del_DT</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field><Field Name="Sec_chek"><DataField>Sec_chek</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="Cover_sheet"><DataField>Cover_sheet</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="CFI_Letter"><DataField>CFI_Letter</DataField><rd:TypeName>System.Int32</rd:TypeName></Field></Fields></DataSet><DataSet Name="DataSet2"><Query><DataSourceName>DLIUDW01</DataSourceName><CommandText>SELECT POL_ID = RTRIM(POL.POL_ID),
CONCAT(RTRIM(PONM.ENTR_SUR_NM),' ', RTRIM(PONM.ENTR_GIV_NM)) PO_NAME,
POL_STATUS = RTRIM(STAT.DM_AV_DESC_TXT)
FROM SGTB_POLICY POL
LEFT JOIN SGTB_POLICY_CLIENT PC ON PC.POL_ID = POL.POL_ID AND PC.POL_CLI_REL_TYP_CD = 'O'
LEFT JOIN (SELECT #NO = ROW_NUMBER() OVER(PARTITION BY CLI_ID ORDER BY PREV_UPDT_TS DESC), * FROM SGTM_CLIENT_IND WHERE LEN(CLI_ID) &gt;= 10) PONM ON PC.CLI_ID= PONM.CLI_ID AND PONM.#NO = 1
LEFT JOIN SGTM_PARA_1 STAT ON STAT.DM_AV_CD = POL.POL_CSTAT_CD AND STAT.DM_AV_TBL_CD = 'POL-CSTAT-CD' AND STAT.DM_AV_DESC_LANG_CD = 'E'</CommandText></Query><Fields><Field Name="POL_ID"><DataField>POL_ID</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="PO_NAME"><DataField>PO_NAME</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="POL_STATUS"><DataField>POL_STATUS</DataField><rd:TypeName>System.String</rd:TypeName></Field></Fields></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Tablix Name="Tablix1"><TablixBody><TablixColumns><TablixColumn><Width>0.54861in</Width></TablixColumn><TablixColumn><Width>1.23611in</Width></TablixColumn><TablixColumn><Width>1.3125in</Width></TablixColumn><TablixColumn><Width>1.59722in</Width></TablixColumn><TablixColumn><Width>3.125in</Width></TablixColumn><TablixColumn><Width>1.73611in</Width></TablixColumn><TablixColumn><Width>1.63889in</Width></TablixColumn><TablixColumn><Width>1.59722in</Width></TablixColumn><TablixColumn><Width>1.88889in</Width></TablixColumn><TablixColumn><Width>2.5in</Width></TablixColumn><TablixColumn><Width>1.63889in</Width></TablixColumn><TablixColumn><Width>1.20833in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn></TablixColumns><TablixRows><TablixRow><Height>0.25in</Height><TablixCells><TablixCell><CellContents><Textbox Name="Textbox71"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>No</Value><Style><FontFamily>Arial</FontFamily><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><rd:DefaultName>Textbox71</rd:DefaultName><Style><Border><Color>LightGrey</Color><Style>Solid</Style></Border><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom><