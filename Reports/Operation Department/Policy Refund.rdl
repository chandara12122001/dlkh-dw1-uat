    r.application_number, 
    r.policy_number,
    STRING_AGG(rd.rule_code || ':' || rd.rule_result_code, ',') AS rule_codes
FROM 
    "result" r 
LEFT JOIN 
    result_detail rd 
    ON rd.result_id = r.id 
GROUP BY 
    r.application_number, 
    r.policy_number</CommandText></Query><Fields><Field Name="application_number"><DataField>application_number</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="policy_number"><DataField>policy_number</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="rule_codes"><DataField>rule_codes</DataField><rd:TypeName>System.String</rd:TypeName></Field></Fields></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Tablix Name="Tablix1"><TablixBody><TablixColumns><TablixColumn><Width>0.63333in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1.19167in</Width></TablixColumn><TablixColumn><Width>2in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>0.8in</Width></TablixColumn><TablixColumn><Width>0.8in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1.11111in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1.20139in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>4.5in</Width></TablixColumn><TablixColumn><Width>3.5in</Width></TablixColumn><TablixColumn><Width>1.5in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>0.9in</Width></TablixColumn><TablixColumn><Width>0.9in</Width></TablixColumn><TablixColumn><Width>1.8in</Width></TablixColumn><TablixColumn><Width>2in</Width></TablixColumn><TablixColumn><Width>1.5in</Width></TablixColumn><TablixColumn><Width>2.5in</Width></TablixColumn><TablixColumn><Width>1.2in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1.2in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1i