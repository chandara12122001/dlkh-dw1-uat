<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df"><df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily><AutoRefresh>0</AutoRefresh><DataSources><DataSource Name="DataSource1"><ConnectionProperties><DataProvider>SQL</DataProvider><ConnectString>Data Source=10.116.18.63;Initial Catalog=DLKHSTAGE</ConnectString><Prompt>Specify a user name and password for data source DataSource1:</Prompt></ConnectionProperties><rd:SecurityType>DataBase</rd:SecurityType><rd:DataSourceID>c8b86f24-338e-4d0b-9e8f-088bd53726f5</rd:DataSourceID></DataSource></DataSources><DataSets><DataSet Name="DataSet1"><Query><DataSourceName>DataSource1</DataSourceName><QueryParameters><QueryParameter Name="@POL_ID"><Value>=Parameters!POL_ID.Value</Value></QueryParameter></QueryParameters><CommandText>SELECT  POLC.POL_ID, CVG.CVG_MAT_XPRY_DT, PO_NAME = RTRIM(CLNM.ENTR_SUR_NM) + ' ' + RTRIM(CLNM.ENTR_GIV_NM)
FROM SGTB_POLICY_CLIENT POLC
INNER JOIN SGTM_COVERAGE CVG ON POLC.POL_ID = CVG.POL_ID AND CVG.CVG_NUM = '01'
INNER JOIN SGTM_CLIENT_IND CLNM ON POLC.CLI_ID = CLNM.CLI_ID
WHERE POLC.POL_ID = @POL_ID</CommandText></Query><Fields><Field Name="POL_ID"><DataField>POL_ID</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="CVG_MAT_XPRY_DT"><DataField>CVG_MAT_XPRY_DT</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field><Field Name="PO_NAME"><DataField>PO_NAME</DataField><rd:TypeName>System.String</rd:TypeName></Field></Fields></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Tablix Name="Tablix1"><TablixBody><TablixColumns><TablixColumn><Width>0.22in</Width></TablixColumn><TablixColumn><Width>0.35in</Width></TablixColumn><TablixColumn><Width>4.4in</Width></TablixColumn><TablixColumn><Width>1.18in</Width></TablixColumn><TablixColumn><Width>5in</Width></TablixColumn></TablixColumns><TablixRows><TablixRow><Height>0.25in</Height><TablixCells><TablixCell><CellContents><Textbox Name="Textbox246"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value /><Style /></TextRun></TextRuns><Style /></Paragraph></Paragraphs><rd:DefaultName>Textbox246</rd:DefaultName><Style><Border><Style>None</Style></Border><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox><ColSpan>5</ColSpan></CellContents></TablixCell><TablixCell /><TablixCell /><TablixCell /><TablixCell /></TablixCells></TablixRow><TablixRow><Height>1.2in</Height><TablixCells><TablixCell><CellContents><Rectangle Name="Rectangle2"><ReportItems><Image Name="Dai_ichi_logo2"><Source>Embedded</Source><Value>UEF_logo</Value><Sizing>FitProportional</Sizing><Left>2in</Left><Height>1.1in</Height><Width>1.55in</Width><Style><Border><Style>None</Style></Border></Style></Image></ReportItems><KeepTogether>true</KeepTogether><Style><Border><Style>None</Style></Border></Style></Rectangle><ColSpan>3</ColSpan></CellContents></TablixCell><TablixCell /><TablixCell /><TablixCell><CellContents><Textbox Name="Textbox244"><CanGrow>true<