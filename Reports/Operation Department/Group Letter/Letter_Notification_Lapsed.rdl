</FontFamily><FontWeight>Normal</FontWeight><TextDecoration>None</TextDecoration><Color>#000000</Color></Style></TextRun><TextRun><Label>PD_TO_DT</Label><Value>=First(Fields!PAID_TO_DATE.Value, "POL_INFO")</Value><Style><FontStyle>Normal</FontStyle><FontFamily>Arial</FontFamily><FontWeight>Normal</FontWeight><TextDecoration>None</TextDecoration><Color>#000000</Color></Style></TextRun><TextRun><Value>? ??????? ??????????????? </Value><Style><FontStyle>Normal</FontStyle><FontFamily>Kh Siemreap</FontFamily><FontWeight>Normal</FontWeight><TextDecoration>None</TextDecoration><Color>#000000</Color></Style></TextRun><TextRun><Label>LAPSE_DT</Label><Value>=First(Fields!LAPSED_DATE.Value, "POL_INFO")</Value><Style><FontStyle>Normal</FontStyle><FontFamily>Arial</FontFamily><FontWeight>Normal</FontWeight><TextDecoration>None</TextDecoration><Color>#000000</Color></Style></TextRun><TextRun><Value xml:space="preserve">  </Value><Style><FontStyle>Normal</FontStyle><FontFamily>Kh Siemreap</FontFamily><FontWeight>Normal</FontWeight><TextDecoration>None</TextDecoration><Color>#a6a6a6</Color></Style></TextRun><TextRun><Value>???????????????????</Value><Style><FontStyle>Normal</FontStyle><FontFamily>Kh Siemreap</FontFamily><FontWeight>Normal</FontWeight><TextDecoration>None</TextDecoration><Color>#000000</Color></Style></TextRun></TextRuns><Style><TextAlign>Left</TextAlign><LineHeight>10pt</LineHeight></Style></Paragraph><Paragraph><TextRuns><TextRun><Value>????????????????????</Value><Style><FontStyle>Normal</FontStyle><FontFamily>Kh Siemreap</FontFamily><FontWeight>Normal</FontWeight><TextDecoration>None</TextDecoration><Color>#000000</Color></Style></TextRun><TextRun><Value>????????????</Value><Style><FontStyle>Normal</FontStyle><FontFamily>Khmer OS Siemreap</FontFamily><FontWeight>Normal</FontWeight><TextDecoration>None</TextDecoration><Color>#000000</Color></Style></TextRun><TextRun><Value>???? ???????????????????????????????????????????</Value><Style><FontStyle>Normal</FontStyle><FontFamily>Kh Siemreap</FontFamily><FontWeight>Normal</FontWeight><TextDecoration>None</TextDecoration><Color>#000000</Color></Style></TextRun><TextRun><Value>???????????</Value><Style><FontStyle>Normal</FontStyle><FontFamily>Khmer OS Siemreap</FontFamily><FontWeight>Normal</FontWeight><TextDecoration>None</TextDecoration><Color>#000000</Color></Style></TextRun><TextRun><Value>?????????????</Value><Style><FontStyle>Normal</FontStyle><FontFamily>Kh Siemreap</FontFamily><FontWeight>Normal</FontWeight><TextDecoration>None</TextDecoration><Color>#000000</Color></Style></TextRun></TextRuns><Style><TextAlign>Left</TextAlign></Style></Paragraph><Paragraph><TextRuns><TextRun><Value>We are sorry to inform you that your Policy Number     </Value><Style><FontStyle>Normal</FontStyle><FontFamily>Arial</FontFamily><FontWeight>Normal</FontWeight><TextDecoration>None</TextDecoration><Color>#000000</Color></Style></TextRun><TextRun><Label>POL_ID</Label><Value>=First(Fields!POL_ID.Value, "POL_INFO")</Value><Style><FontStyle>Normal</FontStyle><FontFamily>Arial</FontFamily><FontWeight>Normal</FontWeight><TextDecoration>None</TextDecoration><Color>#000000</Color></Style></TextRun><TextRun><Value>     shall be due on     </Value><Style><FontStyle>Normal</FontStyle><FontFamily>Arial</FontFamily><FontWeight>Normal</FontWeight><TextDecoration>None</TextDecoration><Color>#000000</Color></Style></TextRun><TextRun><Label>PD_TO_DT</Label><Value>=First(Fields!PAID_TO_DATE.Value, "POL_INFO")</Value><Style><FontStyle>Normal</FontStyle><FontFamily>Arial</FontFamily><FontWeight>Normal</FontWeight><TextDecoration>None</TextDecoration><Color>#000000</Color></Style></TextRun><TextRun><Value>.  However, until</Value><Style><FontStyle>Normal</FontStyle><FontFamily>Arial</FontFamily><FontWeight>Normal</FontWeight><TextDecoration>None</TextDecoration><Color>#000000</Color></Style></TextRun></TextRuns><Style><TextAlign>Left</TextAlign></Style></Paragraph><Paragraph><TextRuns><TextRun><Label>LAPSED_DT</Lab