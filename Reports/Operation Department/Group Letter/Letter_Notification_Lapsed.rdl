<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df"><df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily><AutoRefresh>0</AutoRefresh><DataSources><DataSource Name="Dataware_House"><DataSourceReference>STAGE_PROD</DataSourceReference><rd:SecurityType>None</rd:SecurityType><rd:DataSourceID>dd3b3f28-3b99-414c-9340-f32ef29f534a</rd:DataSourceID></DataSource></DataSources><DataSets><DataSet Name="POL_INFO"><Query><DataSourceName>Dataware_House</DataSourceName><QueryParameters><QueryParameter Name="@POL_ID"><Value>=Parameters!PolicyId.Value</Value></QueryParameter></QueryParameters><CommandText>SELECT 
REPLACE(CONVERT(VARCHAR,GETDATE(),105),'-','/') AS GEN_DATE,
CASE
	WHEN CLI.CLI_SEX_CD='M' THEN 'Mr'
	WHEN CLI.CLI_SEX_CD='F' THEN 'Ms'
	ELSE ''
END AS CLI_TITLE,
CONCAT(RTRIM(NM.ENTR_SUR_NM),' ',RTRIM(NM.ENTR_GIV_NM)) AS PO_NAME,
RTRIM(CLIA.CLI_ADDR_LN_1_TXT) AS ADDR,
RTRIM(COMMUNE.ETBL_DESC_TXT) AS WARD,
RTRIM(DISTRICT.ETBL_DESC_TXT) AS DISTRICT,
RTRIM(CLIA.CLI_CITY_NM_TXT) AS PROVINCE,
RTRIM(POL.POL_ID) AS POL_ID,
REPLACE(CONVERT(VARCHAR,CONVERT(DATE,dbo.ConvertDate(POL.POL_PD_TO_DT_NUM)),105),'-','/') AS PAID_TO_DATE,
REPLACE(CONVERT(VARCHAR,dbo.ConvertDate(POL.POL_STAT_CHNG_DT),105),'-','/') AS LAPSED_DATE,
POL.POL_CSTAT_CD
FROM SGTB_POLICY POL
LEFT JOIN SGTB_POLICY_CLIENT POL_CLI ON POL.POL_ID=POL_CLI.POL_ID AND POL_CLI.POL_CLI_REL_TYP_CD='O'
LEFT JOIN SGTM_CLIENT CLI ON POL_CLI.CLI_ID=CLI.CLI_ID
LEFT JOIN (SELECT ROW_NUMBER() OVER ( PARTITION BY CLI_ID ORDER BY PREV_UPDT_TS DESC) AS ROWNUMBER, TCLNM.* FROM SGTM_CLIENT_IND TCLNM) NM ON POL_CLI.CLI_ID=NM.CLI_ID AND NM.ROWNUMBER=1
LEFT JOIN (SELECT ROW_NUMBER() OVER ( PARTITION BY CLI_ID ORDER BY CLI_ADDR_EFF_DT DESC) AS ROWNUMBER, TCLIA.* FROM SGTM_CLIENT_ADD TCLIA WHERE TCLIA.CLI_ADDR_TYP_CD='PR') CLIA ON POL_CLI.CLI_ID=CLIA.CLI_ID AND CLIA.ROWNUMBER=1
LEFT JOIN SGTB_EDITTABLE COMMUNE ON CLIA.CLI_ADDR_CNTY_CD=COMMUNE.ETBL_VALU_ID AND COMMUNE.ETBL_TYP_ID='CTYPC' AND COMMUNE.ETBL_LANG_CD='E' AND COMMUNE.CO_ID='CP'
LEFT JOIN SGTB_EDITTABLE DISTRICT ON CLIA.CLI_ADDR_MUN_CD=DISTRICT.ETBL_VALU_ID AND DISTRICT.ETBL_TYP_ID='MCPCD' AND DISTRICT.ETBL_LANG_CD='E' AND DISTRICT.CO_ID='CP'
WHERE POL.POL_CSTAT_CD='B' 
AND POL.POL_ID=@POL_ID</CommandText></Query><Fields><Field Name="GEN_DATE"><DataField>GEN_DATE</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="CLI_TITLE"><DataField>CLI_TITLE</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="PO_NAME"><DataField>PO_NAME</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="ADDR"><DataField>ADDR</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="PAID_TO_DATE"><DataField>PAID_TO_DATE</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="WARD"><DataField>WARD</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="LAPSED_DATE"><DataField>LAPSED_DATE</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="DISTRICT"><DataField>DISTRICT</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="POL_ID"><DataField>POL_ID</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="PROVINCE"><DataField>PROVINCE</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="POL_CSTAT_CD"><DataField>POL_CSTAT_CD</DataField><rd:TypeName>System.String</rd:TypeName></Field></Fields></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Textbox Name="Textbox11"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value /><Style><FontStyle>Normal</FontStyle><FontFamily>Arial</FontFamily><FontWeight>Normal</FontWeight><TextDecoration>None</TextDecoration><Color>#000000</Color></Style></TextRun></TextRuns><Style /></Paragraph><Paragraph><TextRuns><TextRun><Value>???????????/ </Value><Style><FontStyle>Normal</FontStyle><FontFamily>Khmer OS Siemreap</FontFamily><FontWeight>Normal</FontWeight><TextDecoration>None</TextDecoration><Color>#000000</Color></Style></TextRun><TextRun><Value>Date: </Value><Style><FontStyle>Normal</FontStyle><FontFamily>Arial</FontFamily><FontWeight>Normal</FontWeight><TextDecoration>None</TextDecorati