me>appointment_status</rd:DefaultName><Style><Border><Color>#92846e</Color><Style>Solid</Style></Border><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell><TablixCell><CellContents><Textbox Name="created_by"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!created_by.Value</Value><Style><FontFamily>Arial</FontFamily><FontSize>9pt</FontSize></Style></TextRun></TextRuns><Style><TextAlign>Left</TextAlign></Style></Paragraph></Paragraphs><rd:DefaultName>created_by</rd:DefaultName><Style><Border><Color>#92846e</Color><Style>Solid</Style></Border><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell></TablixCells></TablixRow></TablixRows></TablixBody><TablixColumnHierarchy><TablixMembers><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /><TablixMember /></TablixMembers></TablixColumnHierarchy><TablixRowHierarchy><TablixMembers><TablixMember><KeepWithGroup>After</KeepWithGroup></TablixMember><TablixMember><Group Name="Details" /></TablixMember></TablixMembers></TablixRowHierarchy><DataSetName>DataSet1</DataSetName><Height>0.8275in</Height><Width>25.54167in</Width><Style><Border><Style>None</Style></Border><TopBorder><Width>1pt</Width></TopBorder><BottomBorder><Width>1pt</Width></BottomBorder><LeftBorder><Width>1pt</Width></LeftBorder><RightBorder><Width>1pt</Width></RightBorder></Style></Tablix></ReportItems><Height>1.05834in</Height><Style><Border><Style>None</Style></Border><TopBorder><Width>1pt</Width></TopBorder><BottomBorder><Width>1pt</Width></BottomBorder><LeftBorder><Width>1pt</Width></LeftBorder><RightBorder><Width>1pt</Width></RightBorder></Style></Body><Width>28.54167in</Width><Page><PageFooter><Height>0.45in</Height><PrintOnFirstPage>true</PrintOnFirstPage><PrintOnLastPage>true</PrintOnLastPage><Style><Border><Style>None</Style></Border></Style></PageFooter><LeftMargin>1in</LeftMargin><RightMargin>1in</RightMargin><TopMargin>1in</TopMargin><BottomMargin>1in</BottomMargin><Style /></Page></ReportSection></ReportSections><ReportParameters><ReportParameter Name="start_date"><DataType>DateTime</DataType><Prompt>Call Date - From:</Prompt></ReportParameter><ReportParameter Name="end_date"><DataType>DateTime</DataType><Prompt>To:</Prompt></ReportParameter></ReportParameters><ReportParametersLayout><GridLayoutDefinition><NumberOfColumns>4</NumberOfColumns><NumberOfRows>2</NumberOfRows><CellDefinitions><CellDefinition><ColumnIndex>0</ColumnIndex><RowIndex>0</RowIndex><ParameterName>start_date</ParameterName></CellDefinition><CellDefinition><ColumnIndex>1</ColumnIndex><RowIndex>0</RowIndex><ParameterName>end_date</ParameterName></CellDefinition></CellDefinitions></GridLayoutDefinition></ReportParametersLayout><Code>Public Function StripHTML(ByVal sInput As String) As String
IF sInput IsNot Nothing Then 
IF(sInput &lt;&gt;"") Then
Dim objRegExp AS NEW System.Text.RegularExpressions.Regex("&lt;(.|\n)+?&gt;") 

sInput = Replace(sInput, "&lt;BR&gt;", Chr(10))
sInput = Replace(sInput, "&lt;br&gt;", Chr(10))
sInput = Replace(sInput, "&lt;br/&gt;", Chr(10))
sInput = Replace(sInput,"&amp;#160;", " ") 
sInput = Replace(sInput, "&lt;li&gt;", "-")
sInput = Replace(sInput, "&amp;ndash;", "-")
sInput = Replace(sInput, "&amp;mdash;", "-")
sInput = Replace(sInput, "&amp;iexcl;", "ˇ")
sInput = Replace(sInput, "&amp;iquest;", "ż")
sInput = Replace(sInput, "&amp;amp;quot;", "")

sInput = Replace(sInput, "&amp;lsquo;", "‘")
sInput = Replace(sInput, "&amp;rsquo;", "’")
sInput = Replace(sInput, "&amp;laquo;", "«")
sInput = Replace(sInput, "&amp;raquo;", "»")
sInput = Replace(sInput, "&amp;nbsp;", " ")
sInput = Replace(sInput, "&amp;amp;", "&amp;")
sInput = Replace(sInput, "&amp;cent;", "˘")
sInput = Replace(sInput, "&amp;copy;", "©")
sInput = Replace(sInput, "&amp;divide;", "÷")
sInput = Replace(sInput, "&amp;gt;", "&gt;")
sInput = Replace(sInput, "&amp;lt;", "&lt;")
sInput = Replace(sInput, "&amp;micro;", "µ")
sInput = Replace(sInput, "&amp;middot;", "·")
sInput = Replace(sInput, "&amp;para;", "¶")
sInput = Replace(sInput, "&amp;plusmn;", "±")
sInput = Replace(sInput, "&amp;euro;", "€")
sInput = Replace(sInput, "&amp;pound;", "Ł")
sInput = Replace(sInput, "&amp;reg;", "®")
sInput = Replace(sInput, "&amp;sect;", "§")
sInput = Replace(sInput, "&amp;trade;", "™")
sInput = Replace(sInput, "&amp;yen;", "Ą")
sInput = Replace(sInput, "&amp;aacute;", "á")
sInput = Replace(sInput, "&amp;Aacute;", "Á")
sInput = Replace(sInput, "&amp;agrave;", "ŕ")
sInput = Replace(sInput, "&amp;Agrave;", "Ŕ")
sInput = Replace(sInput, "&amp;acirc;", "â")
sInput = Replace(sInput, "&amp;Acirc;", "Â")
sInput = Replace(sInput, "&amp;aring;", "ĺ")
sInput = Replace(sInput, "&amp;Aring;", "Ĺ")
sInput = Replace(sInput, "&amp;atilde;", "ă")
sInput = Replace(sInput, "&amp;Atilde;", "Ă")
sInput = Replace(sInput, "&amp;auml;", "ä")
sInput = Replace(sInput, "&amp;Auml;", "Ä")
sInput = Replace(sInput, "&amp;aelig;", "ć")
sInput = Replace(sInput, "&amp;AElig;", "Ć")
sInput = Replace(sInput, "&amp;ccedil;", "ç")
sInput = Replace(sInput, "&amp;Ccedil;", "Ç")
sInput = Replace(sInput, "&amp;eacute;", "é")
sInput = Replace(sInput, "&amp;Eacute;", "É")
sInput = Replace(sInput, "&amp;egrave;", "č")
sInput = Replace(sInput, "&amp;Egrave;", "Č")
sInput = Replace(sInput, "&amp;ecirc;", "ę")
sInput = Replace(sInput, "&amp;Ecirc;", "Ę")
sInput = Replace(sInput, "&amp;euml;", "ë")
sInput = Replace(sInput, "&amp;Euml;", "Ë")
sInput = Replace(sInput, "&amp;iacute;", "í")
sInput = Replace(sInput, "&amp;Iacute;", "Í")
sInput = Replace(sInput, "&amp;igrave;", "ě")
sInput = Replace(sInput, "&amp;Igrave;", "Ě")
sInput = Replace(sInput, "&amp;icirc;", "î")
sInput = Replace(sInput, "&amp;Icirc;", "Î")
sInput = Replace(sInput, "&amp;Iuml;", "Ď")
sInput = Replace(sInput, "&amp;ntilde;", "ń")
sInput = Replace(sInput, "&amp;Ntilde;", "Ń")
sInput = Replace(sInput, "&amp;oacute;", "ó")
sInput = Replace(sInput, "&amp;Oacute;", "Ó")
sInput = Replace(sInput, "&amp;ograve;", "ň")
sInput = Replace(sInput, "&amp;Ograve;", "Ň")
sInput = Replace(sInput, "&amp;ocirc;", "ô")
sInput = Replace(sInput, "&amp;Ocirc;", "Ô")
sInput = Replace(sInput, "&amp;oslash;", "ř")
sInput = Replace(sInput, "&amp;Oslash;", "Ř")
sInput = Replace(sInput, "&amp;otilde;", "ő")
sInput = Replace(sInput, "&amp;Otilde;", "Ő")
sInput = Replace(sInput, "&amp;ouml;", "ö")
sInput = Replace(sInput, "&amp;Ouml;", "Ö")
sInput = Replace(sInput, "&amp;szlig;", "ß")
sInput = Replace(sInput, "&amp;uacute;", "ú")
sInput = Replace(sInput, "&amp;Uacute;", "Ú")
sInput = Replace(sInput, "&amp;ugrave;", "ů")
sInput = Replace(sInput, "&amp;Ugrave;", "Ů")
sInput = Replace(sInput, "&amp;ucirc;", "ű")
sInput = Replace(sInput, "&amp;Ucirc;", "Ű")
sInput = Replace(sInput, "&amp;uuml;", "ü")
sInput = Replace(sInput, "&amp;Uuml;", "Ü")
sInput = Replace(sInput, "&amp;yuml;", "˙")
sInput = Replace(sInput, "&amp;#039;", "'")
RETURN objRegExp.Replace(sInput, "")
ELSE 
RETURN sInput
END IF
END IF
End Function
