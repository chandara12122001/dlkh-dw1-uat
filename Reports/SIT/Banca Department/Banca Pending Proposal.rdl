<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df"><df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily><AutoRefresh>0</AutoRefresh><DataSources><DataSource Name="DataSource1"><ConnectionProperties><DataProvider>SQL</DataProvider><ConnectString>Data Source=10.116.17.152;Initial Catalog=SalePortal</ConnectString><IntegratedSecurity>true</IntegratedSecurity></ConnectionProperties><rd:SecurityType>Integrated</rd:SecurityType><rd:DataSourceID>26add077-f85c-44bf-b0f1-40a693303155</rd:DataSourceID></DataSource></DataSources><DataSets><DataSet Name="DataSet1"><Query><DataSourceName>DataSource1</DataSourceName><QueryParameters><QueryParameter Name="@CHANNEL"><Value>=Parameters!CHANNEL.Value</Value></QueryParameter></QueryParameters><CommandText>


--DECLARE @CHANNEL VARCHAR(01)
--SET @CHANNEL = 'B'
SELECT 
  app.id as app_id
, app.number
, pro.name_en as product_name
, app.po_name
, app.created_at AS recived_date
, RTRIM(app.status) AS status
,S.name_en AS app_status
,payment.code as payment_code
,payment.name_en AS payment_mode_en
,BE.PRE_AMT as premium_amount
,BE.MODAL_PRE_AMT as modal_premium_amount
,agt_detail.Name AS fa_name
,up.agent_id
,agt_detail.TitleRole
,CASE 
					WHEN agt_detail.Tier1TitleRole IN('ABM','Bank Region') THEN agt_detail.Tier1Id 
					WHEN agt_detail.Tier2TitleRole IN('ABM','Bank Region') THEN agt_detail.Tier2Id 
					WHEN agt_detail.Tier3TitleRole IN('ABM','Bank Region') THEN agt_detail.Tier3Id 
					WHEN agt_detail.Tier4TitleRole IN('ABM','Bank Region') THEN agt_detail.Tier4Id 
					WHEN agt_detail.Tier5TitleRole IN('ABM','Bank Region') THEN agt_detail.Tier5Id 
					WHEN agt_detail.Tier6TitleRole IN('ABM','Bank Region') THEN agt_detail.Tier6Id 
					WHEN agt_detail.Tier7TitleRole IN('ABM','Bank Region') THEN agt_detail.Tier7Id 
				   END leaderId
,CASE 
					WHEN agt_detail.Tier1TitleRole IN('ABM','Bank Region') THEN agt_detail.Tier1Name 
					WHEN agt_detail.Tier2TitleRole IN('ABM','Bank Region') THEN agt_detail.Tier2Name 
					WHEN agt_detail.Tier3TitleRole IN('ABM','Bank Region') THEN agt_detail.Tier3Name 
					WHEN agt_detail.Tier4TitleRole IN('ABM','Bank Region') THEN agt_detail.Tier4Name 
					WHEN agt_detail.Tier5TitleRole IN('ABM','Bank Region') THEN agt_detail.Tier5Name 
					WHEN agt_detail.Tier6TitleRole IN('ABM','Bank Region') THEN agt_detail.Tier6Name 
					WHEN agt_detail.Tier7TitleRole IN('ABM','Bank Region') THEN agt_detail.Tier7Name 
				   END leaderName
,RTRIM(agt_detail.Branch) Branch

FROM 
applications app
left join products pro on pro.id = app.product_id
left join quotations quo on quo.id = app.quotation_id
left join payment_frequencies payment on payment.id = quo.payment_frequency_id
LEFT JOIN user_profiles up on app.created_by = up.user_id
LEFT JOIN AGENT_DETAIL agt_detail on agt_detail.AgentId = up.agent_id
LEFT JOIN (
		SELECT LI.quotation_id,SUM(B.premium_amount_after_discount) AS PRE_AMT, SUM(B.modal_premium_amount_after_discount) AS MODAL_PRE_AMT FROM benefits B
		LEFT JOIN life_insureds LI ON LI.id = B.life_insured_id GROUP BY LI.quotation_id
	) BE ON BE.quotation_id = quo.id
LEFT JOIN system_defined_field_lists S ON S.code = APP.status AND S.system_defined_field_code in ('app-status')
where app.channel = @CHANNEL AND app.status != 'D' and app.number is not null 
ORDER BY app.number desc</CommandText></Query><Fields><Field Name="app_id"><DataField>app_id</DataField><rd:TypeName>System.Int64</rd:TypeName></Field><Field Name="number"><DataField>number</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="product_name"><DataField>product_name</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="po_name"><DataField>po_name</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="recived_date"><DataField>recived_date</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field><Field Name="status"><DataField>status</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="app_status"><DataField>app_status</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="payment_code"><DataField>payment_code</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="premium_amount"><DataField>premium_amount</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field><Field Name="modal_premium_amount"><DataField>modal_premium_amount</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field><Field Name="payment_mode_en"><DataField>payment_mode_en</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="leaderId"><DataField>leaderId</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="fa_name"><DataField>fa_name</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="leaderName"><DataField>leaderName</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="agent_id"><DataField>agent_id</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="TitleRole"><DataField>TitleRole</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="Branch"><DataField>Branch</DataField><rd:TypeName>System.String</rd:TypeName></Field></Fields></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Tablix Name="Tablix1"><TablixBody><TablixColumns><TablixColumn><