<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df"><df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily><AutoRefresh>0</AutoRefresh><DataSources><DataSource Name="DataSource1"><ConnectionProperties><DataProvider>SQL</DataProvider><ConnectString>Data Source=10.116.17.52;Initial Catalog=HRMIS</ConnectString><Prompt>Specify a user name and password for data source DataSource1:</Prompt></ConnectionProperties><rd:SecurityType>DataBase</rd:SecurityType><rd:DataSourceID>b3d958c6-cab1-4018-a83d-c7e1a1f5b2b2</rd:DataSourceID></DataSource></DataSources><DataSets><DataSet Name="DataSet1"><Query><DataSourceName>DataSource1</DataSourceName><CommandText>USE HRMIS;
WITH 
yearlist AS (
    SELECT (SELECT DISTINCT YEAR(MIN(JoinedDate)) FROM Employee) AS Year
    UNION ALL
    SELECT yl.Year + 1 AS Year
    FROM yearlist yl
    WHERE yl.Year + 1 &lt;= YEAR(GetDate())
),
resignitionByYearService AS (
	SELECT yl.Year,
	SUM(CASE WHEN (DATEDIFF(DAY,JoinedDate,LeftDate)/365.24 &lt; 1) AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS 'Less than 1 year', 
	SUM(CASE WHEN (DATEDIFF(DAY,JoinedDate,LeftDate)/365.24 BETWEEN 1 AND 2)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '1-2 Year(s)',
	SUM(CASE WHEN (DATEDIFF(DAY,JoinedDate,LeftDate)/365.24 BETWEEN 2 AND 3)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '2-3 Years',
	SUM(CASE WHEN (DATEDIFF(DAY,JoinedDate,LeftDate)/365.24 BETWEEN 3 AND 4)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '3-4 Years',
	SUM(CASE WHEN (DATEDIFF(DAY,JoinedDate,LeftDate)/365.24 BETWEEN 4 AND 5)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '4-5 Years',
	SUM(CASE WHEN (DATEDIFF(DAY,JoinedDate,LeftDate)/365.24 BETWEEN 5 AND 6)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '5-6 Years',
	SUM(CASE WHEN (DATEDIFF(DAY,JoinedDate,LeftDate)/365.24 BETWEEN 6 AND 7)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '6-7 Years',
	SUM(CASE WHEN (DATEDIFF(DAY,JoinedDate,LeftDate)/365.24 BETWEEN 7 AND 8)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '7-8 Years',
	SUM(CASE WHEN (DATEDIFF(DAY,JoinedDate,LeftDate)/365.24 BETWEEN 8 AND 9)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '8-9 Years',
	SUM(CASE WHEN (DATEDIFF(DAY,JoinedDate,LeftDate)/365.24 BETWEEN 9 AND 10)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '9-10 Years',
	SUM(CASE WHEN (DATEDIFF(DAY,JoinedDate,LeftDate)/365.24 BETWEEN 10 AND 11)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '10-11 Years',
	SUM(CASE WHEN (DATEDIFF(DAY,JoinedDate,LeftDate)/365.24 BETWEEN 11 AND 12)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '11-12 Years',
	SUM(CASE WHEN (DATEDIFF(DAY,JoinedDate,LeftDate)/365.24 BETWEEN 12 AND 13)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '12-13 Years',
	SUM(CASE WHEN (DATEDIFF(DAY,JoinedDate,LeftDate)/365.24 BETWEEN 13 AND 14)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '13-14 Years',
	SUM(CASE WHEN (DATEDIFF(DAY,JoinedDate,LeftDate)/365.24 &gt; 14) AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '&gt; 14 years',
	SUM(CASE WHEN YEAR(LeftDate) = yl.year THEN 1 ELSE 0 END) AS Total
	FROM 
	yearlist yl
	JOIN 
	(Person INNER JOIN dbo.Employee ON Person.PersonId = Employee.PersonID) ON 1 = 1
	WHERE YEAR(JoinedDate) &lt;= yl.Year AND Employee.Status = 'Resigned' AND LeftDate IS NOT NULL 
	GROUP BY yl.Year
)

SELECT newtabl.*, Total
FROM
resignitionByYearService
CROSS APPLY(
	VALUES
		(Year,	"Less than 1 year",'aLess than 1 year'),
		(Year,	"1-2 Year(s)",'b1-2 Year(s)'),
		(Year,	"2-3 Years",'c2-3 Years'),
		(Year,	"3-4 Years",'d3-4 Years'),
		(Year,	"4-5 Years",'e4-5 Years'),
		(Year,	"5-6 Years",'f5-6 Years'),
		(Year,	"6-7 Years",'g6-7 Years'),
		(Year,	"7-8 Years",'h7-8 Years'),
		(Year,	"8-9 Years",'i8-9 Years'),
		(Year,	"9-10 Years",'j9-10 Years'),
		(Year,	"10-11 Years",'k10-11 Years'),
		(Year,	"11-12 Years",'l11-12 Years'),
		(Year,	"12-13 Years",'m12-13 Years'),
		(Year,	"13-14 Years",'n13-14 Years'),
		(Year,	"&gt; 14 years",'o&gt; 14 years')

) newtabl(Year, Num, year_separate)</CommandText><rd:UseGenericDesigner>true</rd:UseGenericDesigner></Query><Fields><Field Name="Year"><DataField>Year</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="Num"><DataField>Num</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="year_separate"><DataField>year_separate</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="Total"><DataField>Total</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="catagog"><Value>=Right(Fields!year_separate.Value, Len(Fields!year_separate.Value)-1)</Value></Field></Fields><Filters><Filter><FilterExpression>=Fields!Year.Value</FilterExpression><Operator>GreaterThanOrEqual</Operator><FilterValues><FilterValue>=Parameters!start_year.Value</FilterValue></FilterValues></Filter><Filter><FilterExpression>=Fields!Year.Value</FilterExpression><Operator>LessThanOrEqual</Operator><FilterValues><FilterValue>=Parameters!end_year.Value</FilterValue></FilterValues></Filter></Filters></DataSet><DataSet Name="yearlist"><Query><DataSourceName>DataSource1</DataSourceName><CommandText>USE HRMIS;
WITH 
yearlist AS (
    SELECT 
		(SELECT DISTINCT YEAR(MIN(JoinedDate)) FROM Employee) AS Year
		UNION ALL
		SELECT yl.Year + 1 AS Year
    FROM yearlist yl
    WHERE yl.Year + 1 &lt;= YEAR(GetDate())
)
SELECT * FROM yearlist;</CommandText></Query><Fields><Field Name="Year"><DataField>Year</DataField><rd:TypeName>System.Int32</rd:TypeName></Field></Fields></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Textbox Name="ReportTitle"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value> Staff Resignation by Year in Service</Value><Style><FontFamily>Arial</FontFamily><FontSize>18pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Left</TextAlign></Style></Paragraph></Paragraphs><rd:WatermarkTextbox>Title</rd:WatermarkTextbox><rd:DefaultName>ReportTitle</rd:DefaultName><Left>0.23833in</Left><Height>0.60417in</Height><Width>7.44792in</Width><Style><Border><Style>None</Style></Border><BackgroundColor>DarkBlue</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox><Tablix Name="Tablix1"><TablixCorner><TablixCornerRows><TablixCornerRow><TablixCornerCell><CellContents><Textbox Name="Textbox7"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>Status</Value><Style><FontFamily>Arial</FontFamily><FontSize>12pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs><rd:DefaultName>Textbox7</rd:DefaultName><Style><Border><Color>LightGrey</Color><Style>Solid</Style></Border><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCornerCell></TablixCornerRow></TablixCornerRows></TablixCorner><TablixBody><TablixColumns><TablixColumn><Width>0.69167in</Width></TablixColumn><TablixColumn><Width>0.74167in</Width></TablixColumn></TablixColumns><TablixRows><TablixRow><Height>0.38333in</Height><TablixCells><TablixCell><CellContents><Textbox Name="Num"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!Num.Value</Value><Style><FontFamily>Arial</FontFamily><FontSize>12pt</FontSize></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><rd:DefaultName>Num</rd:DefaultName><Style><Border><Color>LightGrey</Color><Style>Solid</Style></Border><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell><TablixCell><CellContents><Textbox Name="Textbox12"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIf(Fields!Total.Value = 0, 0, Fields!Num.Value/Fields!Total.Value)</Value><Style><FontFamily>Arial</FontFamily><FontSize>12pt</FontSize><Format>0.00%</Format></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><rd:DefaultName>Textbox12</rd:DefaultName><Style><Border><Color>LightGrey</Color><Style>Solid</Style></Border><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell></TablixCells></TablixRow><TablixRow><Height>0.26667in</Height><TablixCells><TablixCell><CellContents><Textbox Name="Total"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!Total.Value</Value><Style><FontFamily>Arial</FontFamily><FontSize>12pt</FontSize></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><rd:DefaultName>Total</rd:DefaultName><Style><Border><Color>LightGrey</Color><Style>Solid</Style></Border><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><Padd