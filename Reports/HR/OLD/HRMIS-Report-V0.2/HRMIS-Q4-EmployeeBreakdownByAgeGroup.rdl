<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df"><df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily><AutoRefresh>0</AutoRefresh><DataSources><DataSource Name="DataSource1"><ConnectionProperties><DataProvider>SQL</DataProvider><ConnectString>Data Source=10.116.17.52;Initial Catalog=HRMIS</ConnectString><Prompt>Specify a user name and password for data source DataSource1:</Prompt></ConnectionProperties><rd:SecurityType>DataBase</rd:SecurityType><rd:DataSourceID>b3d958c6-cab1-4018-a83d-c7e1a1f5b2b2</rd:DataSourceID></DataSource></DataSources><DataSets><DataSet Name="yearlist"><Query><DataSourceName>DataSource1</DataSourceName><CommandText>USE HRMIS;
WITH 
yearlist AS (
    SELECT 
		(SELECT DISTINCT YEAR(MIN(JoinedDate)) FROM Employee) AS Year
		UNION ALL
		SELECT yl.Year + 1 AS Year
    FROM yearlist yl
    WHERE yl.Year + 1 &lt;= YEAR(GetDate())
)
SELECT * FROM yearlist;</CommandText></Query><Fields><Field Name="Year"><DataField>Year</DataField><rd:TypeName>System.Int32</rd:TypeName></Field></Fields></DataSet><DataSet Name="employyee_classified_into_age_group"><Query><DataSourceName>DataSource1</DataSourceName><CommandText>USE HRMIS;
WITH 
yearlist AS (
    SELECT (SELECT DISTINCT YEAR(MIN(JoinedDate)) FROM Employee) AS Year
    UNION ALL
    SELECT yl.Year + 1 AS Year
    FROM yearlist yl
    WHERE yl.Year + 1 &lt;= YEAR(GetDate())
),
employyee_classified_into_age_group AS (
	SELECT yl.Year,
	SUM(CASE WHEN (ROUND(DATEDIFF(DAY, Person.DateOfBirth, DATEFROMPARTS(yl.Year, 12, 31))/365.24,0) &lt; 18)				AND (LeftDate IS NULL OR (DATEDIFF(DAY, DATEFROMPARTS(yl.Year, 12, 31), LeftDate)/365.24 &gt; 0)) THEN 1 ELSE 0 END) AS 'Less than 18 year-old', 
	SUM(CASE WHEN (ROUND(DATEDIFF(DAY, Person.DateOfBirth, DATEFROMPARTS(yl.Year, 12, 31))/365.24,0) BETWEEN 18 AND 30)	AND (LeftDate IS NULL OR (DATEDIFF(DAY, DATEFROMPARTS(yl.Year, 12, 31), LeftDate)/365.24 &gt; 0)) THEN 1 ELSE 0 END) AS '18 - 30 year-old',
	SUM(CASE WHEN (ROUND(DATEDIFF(DAY, Person.DateOfBirth, DATEFROMPARTS(yl.Year, 12, 31))/365.24,0) BETWEEN 31 AND 40)	AND (LeftDate IS NULL OR (DATEDIFF(DAY, DATEFROMPARTS(yl.Year, 12, 31), LeftDate)/365.24 &gt; 0)) THEN 1 ELSE 0 END) AS '31 - 40 year-old',
	SUM(CASE WHEN (ROUND(DATEDIFF(DAY, Person.DateOfBirth, DATEFROMPARTS(yl.Year, 12, 31))/365.24,0) BETWEEN 41 AND 50)	AND (LeftDate IS NULL OR (DATEDIFF(DAY, DATEFROMPARTS(yl.Year, 12, 31), LeftDate)/365.24 &gt; 0)) THEN 1 ELSE 0 END) AS '41 - 50 year-old',
	SUM(CASE WHEN (ROUND(DATEDIFF(DAY, Person.DateOfBirth, DATEFROMPARTS(yl.Year, 12, 31))/365.24,0) BETWEEN 51 AND 60)	AND (LeftDate IS NULL OR (DATEDIFF(DAY, DATEFROMPARTS(yl.Year, 12, 31), LeftDate)/365.24 &gt; 0)) THEN 1 ELSE 0 END) AS '51 - 60 year-old',
	SUM(CASE WHEN (ROUND(DATEDIFF(DAY, Person.DateOfBirth, DATEFROMPARTS(yl.Year, 12, 31))/365.24,0) &gt; 60)				AND (LeftDate IS NULL OR (DATEDIFF(DAY, DATEFROMPARTS(yl.Year, 12, 31), LeftDate)/365.24 &gt; 0)) THEN 1 ELSE 0 END) AS ' &gt; 60 year-old ',
	SUM(CASE WHEN (LeftDate IS NULL OR (DATEDIFF(DAY, DATEFROMPARTS(yl.Year, 12, 31), LeftDate)/365.24 &gt; 0)) THEN 1 ELSE 0 END) as Total
	FROM 
	yearlist yl
	JOIN 
	(Person INNER JOIN dbo.Employee ON Person.PersonId = Employee.PersonID) ON 1 = 1
	WHERE YEAR(JoinedDate) &lt;= yl.Year 
	GROUP BY yl.Year
)
SELECT * FROM employyee_classified_into_age_group;</CommandText></Query><Fields><Field Name="Year"><DataField>Year</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="Less_than_18_year_old"><DataField>Less than 18 year-old</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="ID18___30_year_old"><DataField>18 - 30 year-old</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="ID31___40_year_old"><DataField>31 - 40 year-old</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="ID41___50_year_old"><DataField>41 - 50 year-old</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="ID51___60_year_old"><DataField>51 - 60 year-old</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="ID___60_year_old_"><DataField> &gt; 60 year-old </DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="Total"><DataField>Total</DataField><rd:TypeName>System.Int32</rd:TypeName></Field></Fields><Filters><Filter><FilterExpression>=Fields!Year.Value</FilterExpression><Operator>GreaterThanOrEqual</Operator><FilterValues><FilterValue>=Parameters!start_year.Value</FilterValue></FilterValues></Filter><Filter><FilterExpression>=Fields!Year.Value</FilterExpression><Operator>LessThanOrEqual</Operator><FilterValues><FilterValue>=Parameters!end_year.Value</FilterValue></FilterValues></Filter></Filters></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Textbox Name="ReportTitle"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value xml:space="preserve"> </Value><Style><FontFamily>Segoe UI Black</FontFamily><FontSize>28pt</FontSize><Color>White</Color></Style></TextRun><TextRun><Value>Employee Break Down by Age Group</Value><Style><FontFamily>Arial</FontFamily><FontSize>20pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs><rd:WatermarkTextbox>Title</rd:WatermarkTextbox><rd:DefaultName>ReportTitle</rd:DefaultName><Left>0.20709in</Left><Height>0.60417in</Height><Width>5.69792in</Width><Style><Border><Style>None</Style></Border><BackgroundColor>DarkBlue</BackgroundColor><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox><Tablix Name="Tablix1"><TablixCorner><TablixCornerRows><TablixCornerRow><TablixCornerCell><CellContents><Textbox Name="Textbox4"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value /><Style><FontSize>12pt</FontSize></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs><rd:DefaultName>Textbox4</rd:DefaultName><Style><Border><Color>LightGrey</Color><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCornerCell></TablixCornerRow></TablixCornerRows></TablixCorner><TablixBody><TablixColumns><TablixColumn><Width>0.68229in</Width></TablixColumn></TablixColumns><TablixRows><TablixRow><Height>0.29167in</Height><TablixCells><TablixCell><CellContents><Textbox Name="Less_than_18_year_old"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!Less_than_18_year_old.Value</Value><Style><FontSize>12pt</FontSize></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><rd:DefaultName>Less_than_18_year_old</rd:DefaultName><Style><Border><Color>LightGrey</Color><Style>Solid</Style></Border><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell></TablixCells></TablixRow><TablixRow><Height>0.25in</Height><TablixCells><TablixCell><CellContents><Textbox Name="ID18___30_year_old">