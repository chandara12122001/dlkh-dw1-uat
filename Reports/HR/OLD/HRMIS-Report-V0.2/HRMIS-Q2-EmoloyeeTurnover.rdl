<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df"><df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily><AutoRefresh>0</AutoRefresh><DataSources><DataSource Name="HRMIS_DataSource"><ConnectionProperties><DataProvider>SQL</DataProvider><ConnectString>Data Source=10.116.17.52;Initial Catalog=HRMIS</ConnectString><Prompt>Specify a user name and password for data source HRMIS_DataSource:</Prompt></ConnectionProperties><rd:SecurityType>DataBase</rd:SecurityType><rd:DataSourceID>171e8b4b-1c92-44d0-a58a-c6d0d9a27237</rd:DataSourceID></DataSource></DataSources><DataSets><DataSet Name="report1"><Query><DataSourceName>HRMIS_DataSource</DataSourceName><CommandText>USE HRMIS;
WITH 
yearlist AS (
    SELECT 
		(SELECT DISTINCT YEAR(MIN(JoinedDate)) FROM Employee) AS Year
		UNION ALL
		SELECT yl.Year + 1 AS Year
    FROM yearlist yl
    WHERE yl.Year + 1 &lt;= YEAR(GetDate())
),
employee_turnover AS (
	SELECT 
		yl.Year,
		SUM(CASE WHEN (YEAR(LeftDate) = yl.Year) THEN 1 ELSE 0 END) AS 'Total Employee Leaving',
		(	--AVERAGE NUMBER OF EMPLOYEE OF A YEAR IS EQUAL TO NUMBER OF EMPLOYEE ON FIRST DAY OF THE YEAR
		SUM(CASE WHEN (JoinedDate &lt;= DATEFROMPARTS(yl.Year, 1, 1)	AND (LeftDate IS NULL OR DATEFROMPARTS(yl.Year, 1, 1)	&lt;= LeftDate)) THEN 1 ELSE 0 END) 
		+	--PLUS NUMBER OF EMPLOYEE OF THE END OF THAT YEAR DIVIED BY 2
		SUM(CASE WHEN (JoinedDate &lt;= DATEFROMPARTS(yl.Year, 12, 31)	AND (LeftDate IS NULL OR DATEFROMPARTS(yl.Year, 12, 31)	&lt;= LeftDate)) THEN 1 ELSE 0 END)
		)/2.0  AS 'Average number of employee as of day'
	FROM 
		yearlist yl
		JOIN 
		(Person INNER JOIN dbo.Employee ON Person.PersonId = Employee.PersonID) ON 1 = 1
	WHERE YEAR(JoinedDate) &lt;= yl.Year 
	GROUP BY yl.Year
)
SELECT * FROM employee_turnover;</CommandText><rd:UseGenericDesigner>true</rd:UseGenericDesigner></Query><Fields><Field Name="year"><DataField>Year</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="Total_Employee_Leaving"><DataField>Total Employee Leaving</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="Average_number_of_employee_as_of_day"><DataField>Average number of employee as of day</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field></Fields><Filters><Filter><FilterExpression>=Fields!year.Value</FilterExpression><Operator>GreaterThanOrEqual</Operator><FilterValues><FilterValue>=Parameters!start_year.Value</FilterValue></FilterValues></Filter><Filter><FilterExpression>=Fields!year.Value</FilterExpression><Operator>LessThanOrEqual</Operator><FilterValues><FilterValue>=Parameters!end_year.Value</FilterValue></FilterValues></Filter></Filters></DataSet><DataSet Name="yearlist"><Query><DataSourceName>HRMIS_DataSource</DataSourceName><CommandText>USE HRMIS;
WITH 
yearlist AS (
    SELECT 
		(SELECT DISTINCT YEAR(MIN(JoinedDate)) FROM Employee) AS Year
		UNION ALL
		SELECT yl.Year + 1 AS Year
    FROM yearlist yl
    WHERE yl.Year + 1 &lt;= YEAR(GetDate())
)
SELECT * FROM yearlist;</CommandText></Query><Fields><Field Name="Year"><DataField>Year</DataField><rd:TypeName>System.Int32</rd:TypeName></Field></Fields></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Textbox Name="ReportTitle"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>Employee Turnover</Value><Style><FontFamily>Arial</FontFamily><FontSize>20pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Left</TextAlign></Style></Paragraph></Paragraphs><rd:WatermarkTextbox>Title</rd:WatermarkTextbox><rd:DefaultName>ReportTitle</rd:DefaultName><Top>0mm</Top><Left>0.17708in</Left><Height>12.7mm</Height><Width>139.7mm</Width><Style><Border><Style>None</Style></Border><BackgroundColor>#002060</BackgroundColor><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox><Tablix Name="Tablix2"><TablixCorner><TablixCornerRows><TablixCornerRow><TablixCornerCell><CellContents><Textbox Name="Textbox41"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>Status</Value><Style><FontFamily>Arial</FontFamily><FontSize>12pt</FontSize></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><rd:DefaultName>Textbox41</rd:DefaultName><Style><Border><Color>LightGrey</Color><Style>Solid</Style></Border><BackgroundColor>DarkGray</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCornerCell></TablixCornerRow></TablixCornerRows></TablixCorner><TablixBody><TablixColumns><TablixColumn><Width>21.03125mm</Width></TablixColumn></TablixColumns><TablixRows><TablixRow><Height>12.6675mm</Height><TablixCells><TablixCell><CellConten