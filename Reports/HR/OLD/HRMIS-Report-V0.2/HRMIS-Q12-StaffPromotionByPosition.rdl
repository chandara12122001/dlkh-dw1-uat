<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df"><df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily><AutoRefresh>0</AutoRefresh><DataSources><DataSource Name="DataSource1"><ConnectionProperties><DataProvider>SQL</DataProvider><ConnectString>Data Source=10.116.17.52;Initial Catalog=HRMIS</ConnectString><Prompt>Specify a user name and password for data source DataSource1:</Prompt></ConnectionProperties><rd:SecurityType>DataBase</rd:SecurityType><rd:DataSourceID>b3d958c6-cab1-4018-a83d-c7e1a1f5b2b2</rd:DataSourceID></DataSource></DataSources><DataSets><DataSet Name="yearlist"><Query><DataSourceName>DataSource1</DataSourceName><CommandText>USE HRMIS;
WITH 
yearlist AS (
    SELECT 
		(SELECT DISTINCT YEAR(MIN(JoinedDate)) FROM Employee) AS Year
		UNION ALL
		SELECT yl.Year + 1 AS Year
    FROM yearlist yl
    WHERE yl.Year + 1 &lt;= YEAR(GetDate())
)
SELECT * FROM yearlist;</CommandText></Query><Fields><Field Name="Year"><DataField>Year</DataField><rd:TypeName>System.Int32</rd:TypeName></Field></Fields></DataSet><DataSet Name="Resignation_by_Position"><Query><DataSourceName>DataSource1</DataSourceName><CommandText>USE HRMIS;
WITH 
yearlist AS (
    SELECT 
		(SELECT DISTINCT YEAR(MIN(JoinedDate)) FROM Employee) AS Year
		UNION ALL
		SELECT yl.Year + 1 AS Year
    FROM yearlist yl
    WHERE yl.Year + 1 &lt;= YEAR(GetDate())
),
Staff_promotion_by_position AS (
	SELECT yl.Year,
		SUM(CASE WHEN Position.Code = ' ' THEN 1 ELSE 0 END) AS 'Head of department',
		SUM(CASE WHEN Position.Code = ' ' THEN 1 ELSE 0 END) AS 'Senior Manager',
		SUM(CASE WHEN Position.Code = ' ' THEN 1 ELSE 0 END) AS 'Manager',
		SUM(CASE WHEN Position.Code = ' ' THEN 1 ELSE 0 END) AS 'Senior Officer',
		SUM(CASE WHEN Position.Code = ' ' THEN 1 ELSE 0 END) AS 'Officer',
		SUM(CASE WHEN Position.Code = ' ' THEN 1 ELSE 0 END) AS 'Intern',
		SUM(CASE WHEN (LeftDate IS NULL OR ( yl.Year &lt;= YEAR(LeftDate))) THEN 1 ELSE 0 END) as Total
	FROM
		yearlist yl
		JOIN 
		(
		Employee 
		INNER JOIN EmployeeHistory ON Employee.EmployeeId = EmployeeHistory.EmployeeId 
		INNER JOIN Position ON EmployeeHistory.PositionId = Position.PositionId
		) ON 1 = 1
	WHERE YEAR(JoinedDate) &lt;= yl.Year
	GROUP BY yl.Year  
)
SELECT * FROM Staff_promotion_by_position;</CommandText><rd:UseGenericDesigner>true</rd:UseGenericDesigner></Query><Fields><Field Name="Year"><DataField>Year</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="Head_of_department"><DataField>Head of department</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="Senior_Manager"><DataField>Senior Manager</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="Manager"><DataField>Manager</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="Senior_Officer"><DataField>Senior Officer</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="Officer"><DataField>Officer</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="Intern"><DataField>Intern</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="Total"><DataField>Total</DataField><rd:TypeName>System.Int32</rd:TypeName></Field></Fields><Filters><Filter><FilterExpression>=Fields!Year.Value</FilterExpression><Operator>GreaterThanOrEqual</Operator><FilterValues><FilterValue>=Parameters!start_year.Value</FilterValue></FilterValues></Filter><Filter><FilterExpression>=Fields!Year.Value</FilterExpression><Operator>LessThanOrEqual</Operator><FilterValues><FilterValue>=Parameters!end_year.Value</FilterValue></FilterValues></Filter></Filters></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Textbox Name="ReportTitle"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value xml:space="preserve"> </Value><Style><FontFamily>Segoe UI Black</FontFamily><FontSize>28pt</FontSize><Color>White</Color></Style></TextRun><TextRun><Value>Staff Promotion By Position</Value><Style><FontFamily>Arial</FontFamily><FontSize>20pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs><rd:WatermarkTextbox>Title</rd:WatermarkTextbox><rd:DefaultName>Re