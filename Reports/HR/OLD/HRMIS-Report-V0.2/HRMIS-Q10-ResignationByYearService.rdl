<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df"><df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily><AutoRefresh>0</AutoRefresh><DataSources><DataSource Name="DataSource1"><ConnectionProperties><DataProvider>SQL</DataProvider><ConnectString>Data Source=10.116.17.52;Initial Catalog=HRMIS</ConnectString><Prompt>Specify a user name and password for data source DataSource1:</Prompt></ConnectionProperties><rd:SecurityType>DataBase</rd:SecurityType><rd:DataSourceID>b3d958c6-cab1-4018-a83d-c7e1a1f5b2b2</rd:DataSourceID></DataSource></DataSources><DataSets><DataSet Name="DataSet1"><Query><DataSourceName>DataSource1</DataSourceName><CommandText>USE HRMIS;
WITH 
yearlist AS (
    SELECT (SELECT DISTINCT YEAR(MIN(JoinedDate)) FROM Employee) AS Year
    UNION ALL
    SELECT yl.Year + 1 AS Year
    FROM yearlist yl
    WHERE yl.Year + 1 &lt;= YEAR(GetDate())
),
resignitionByYearService AS (
	SELECT yl.Year,
	SUM(CASE WHEN (DATEDIFF(MONTH,JoinedDate,LeftDate)/12.0 &lt; 1) AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS 'Less than 1 year', 
	SUM(CASE WHEN (DATEDIFF(MONTH,JoinedDate,LeftDate)/12.0 BETWEEN 1 AND 2)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '1-2 Year(s)',
	SUM(CASE WHEN (DATEDIFF(MONTH,JoinedDate,LeftDate)/12.0 BETWEEN 2 AND 3)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '2-3 Years',
	SUM(CASE WHEN (DATEDIFF(MONTH,JoinedDate,LeftDate)/12.0 BETWEEN 3 AND 4)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '3-4 Years',
	SUM(CASE WHEN (DATEDIFF(MONTH,JoinedDate,LeftDate)/12.0 BETWEEN 4 AND 5)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '4-5 Years',
	SUM(CASE WHEN (DATEDIFF(MONTH,JoinedDate,LeftDate)/12.0 BETWEEN 5 AND 6)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '5-6 Years',
	SUM(CASE WHEN (DATEDIFF(MONTH,JoinedDate,LeftDate)/12.0 BETWEEN 6 AND 7)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '6-7 Years',
	SUM(CASE WHEN (DATEDIFF(MONTH,JoinedDate,LeftDate)/12.0 BETWEEN 7 AND 8)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '7-8 Years',
	SUM(CASE WHEN (DATEDIFF(MONTH,JoinedDate,LeftDate)/12.0 BETWEEN 8 AND 9)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '8-9 Years',
	SUM(CASE WHEN (DATEDIFF(MONTH,JoinedDate,LeftDate)/12.0 BETWEEN 9 AND 10)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '9-10 Years',
	SUM(CASE WHEN (DATEDIFF(MONTH,JoinedDate,LeftDate)/12.0 BETWEEN 10 AND 11)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '10-11 Years',
	SUM(CASE WHEN (DATEDIFF(MONTH,JoinedDate,LeftDate)/12.0 BETWEEN 11 AND 12)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '11-12 Years',
	SUM(CASE WHEN (DATEDIFF(MONTH,JoinedDate,LeftDate)/12.0 BETWEEN 12 AND 13)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '12-13 Years',
	SUM(CASE WHEN (DATEDIFF(MONTH,JoinedDate,LeftDate)/12.0 BETWEEN 13 AND 14)	AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '13-14 Years',
	SUM(CASE WHEN (DATEDIFF(MONTH,JoinedDate,LeftDate)/12.0 &gt; 14) AND YEAR(LeftDate) = yl.Year THEN 1 ELSE 0 END) AS '&gt; 14 years',
	SUM(CASE WHEN YEAR(LeftDate) = yl.year THEN 1 ELSE 0 END) AS Total
	FROM 
	yearlist yl
	JOIN 
	(Person INNER JOIN dbo.Employee ON Person.PersonId = Employee.PersonID) ON 1 = 1
	WHERE YEAR(JoinedDate) &lt;= yl.Year AND Employee.Status = 'Resigned' AND LeftDate IS NOT NULL 
	GROUP BY yl.Year
)
SELECT * FROM resignitionByYearService;</CommandText></Query><Fields><Field Name="Year"><DataField>Year</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="Less_than_1_year"><DataField>Less than 1 year</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="ID1_2_Year_s_"><DataField>1-2 Year(s)</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="ID2_3_Years"><DataField>2-3 Years</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="ID3_4_Years"><DataField>3-4 Years</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="ID4_5_Years"><DataField>4-5 Years</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="ID5_6_Years"><DataField>5-6 Years</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="ID6_7_Years"><DataField>6-7 Years</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="ID7_8_Years"><DataField>7-8 Years</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="ID8_9_Years"><DataField>8-9 Years</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="ID9_10_Years"><DataField>9-10 Years</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="ID10_11_Years"><DataField>10-11 Years</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="ID11_12_Years"><DataField>11-12 Years</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="ID12_13_Years"><DataField>12-13 Years</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="ID13_14_Years"><DataField>13-14 Years</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="ID__14_years"><DataField>&gt; 14 years</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="Total"><DataField>Total</DataField><rd:TypeName>System.Int32</rd:TypeName></Field></Fields><Filters><Filter><FilterExpression>=Fields!Year.Value</FilterExpression><Operator>GreaterThanOrEqual</Operator><FilterValues><FilterValue>=Parameters!start_year.Value</FilterValue></FilterValues></Filter><Filter><FilterExpression>=Fields!Year.Value</FilterExpression><Operator>LessThanOrEqual</Operator><FilterValues><FilterValue>=Parameters!end_year.Value</FilterValue></FilterValues></Filter></Filters></DataSet><DataSet Name="yearlist"><Query><DataSourceName>DataSource1</DataSourceName><CommandText>USE HRMIS;
WITH 
yearlist AS (
    SELECT 
		(SELECT DISTINCT YEAR(MIN(JoinedDate)) FROM Employee) AS Year
		UNION ALL
		SELECT yl.Year + 1 AS Year
    FROM yearlist yl
    WHERE yl.Year + 1 &lt;= YEAR(GetDate())
)
SELECT * FROM yearlist;</CommandText></Query><Fields><Field Name="Year"><DataField>Year</DataField><rd:TypeName>System.Int32</rd:TypeName></Field></Fields></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Textbox Name="ReportTitle"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>Staff Resignation by Year in Service</Value><Style><FontFamily>Arial</FontFamily><FontSize>20pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs><rd:WatermarkTextbox>Title</rd:WatermarkTextbox><rd:DefaultName>ReportTitle</rd:DefaultName><Left>0.23833in</Left><Height>0.60417in</Height><Width>7.44792in</Width><Style><Border><Style>None</Style></Border><BackgroundColor>DarkBlue</BackgroundColor><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox><Tablix Name="Tablix5"><TablixBody><TablixColumns><TablixColumn><Width>1.38542in</Width></TablixColumn><TablixColumn><Width>0.54166in</Width></TablixColumn><TablixColumn><Width>0.54166in</Width></TablixColumn></TablixColumns><TablixRows><TablixRow><Height>0.26562in</Height><TablixCells><TablixCell><CellContents><Textbox Name="Textbox40"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>Total</Value><Style><FontFamily>Arial</FontFamily><FontSize>12pt</FontSize></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs><rd:DefaultName>Textbox40</rd:DefaultName><Style><Border><Color>LightGrey</Color><Style>Solid</Style></Border><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell><TablixCell><CellContents><Textbox Name="Textbox33"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!Tota