<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df"><df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily><AutoRefresh>0</AutoRefresh><DataSources><DataSource Name="DataSource1"><ConnectionProperties><DataProvider>SQL</DataProvider><ConnectString>Data Source=10.116.17.52;Initial Catalog=HRMIS</ConnectString><Prompt>Specify a user name and password for data source DataSource1:</Prompt></ConnectionProperties><rd:SecurityType>DataBase</rd:SecurityType><rd:DataSourceID>b3d958c6-cab1-4018-a83d-c7e1a1f5b2b2</rd:DataSourceID></DataSource></DataSources><DataSets><DataSet Name="yearlist"><Query><DataSourceName>DataSource1</DataSourceName><CommandText>USE HRMIS;
WITH 
yearlist AS (
    SELECT 
		(SELECT DISTINCT YEAR(MIN(JoinedDate)) FROM Employee) AS Year
		UNION ALL
		SELECT yl.Year + 1 AS Year
    FROM yearlist yl
    WHERE yl.Year + 1 &lt;= YEAR(GetDate())
)
SELECT * FROM yearlist;</CommandText></Query><Fields><Field Name="Year"><DataField>Year</DataField><rd:TypeName>System.Int32</rd:TypeName></Field></Fields></DataSet><DataSet Name="employyee_classified_into_department"><Query><DataSourceName>DataSource1</DataSourceName><CommandText>USE HRMIS;
WITH 
yearlist AS (
    SELECT (SELECT DISTINCT YEAR(MIN(JoinedDate)) FROM Employee) AS Year
		UNION ALL
		SELECT yl.Year + 1 AS Year
    FROM yearlist yl
    WHERE yl.Year + 1 &lt;= YEAR(GetDate())
),
bigtable AS (
	SELECT 
		Employee.EmployeeId,
		Employee.JoinedDate,
		MAX(EmployeeHistory.EffectiveDate) AS EffectiveDate,
		Employee.LeftDate,
		yl.Year AS yl_year,
		EmployeeHistory.UnitId AS UnitId
	FROM 
		yearlist yl
		JOIN(
		Employee 
		INNER JOIN EmployeeHistory ON Employee.EmployeeId = EmployeeHistory.EmployeeId 
		INNER JOIN Unit ON EmployeeHistory.UnitId = Unit.UnitId
		) ON 1 = 1
	WHERE YEAR(JoinedDate) &lt;= yl.Year
	GROUP BY yl.Year, EmployeeHistory.UnitId, Employee.LeftDate, Employee.EmployeeId, Employee.JoinedDate
),
small_table AS(
	SELECT 
		yl_Year AS Year,         
		SUM(CASE WHEN UnitId = 1 AND	(DATEDIFF(DAY, DATEFROMPARTS(yl_Year, 12, 31), EffectiveDate)/365.24 &lt; 0) AND (LeftDate IS NULL OR (DATEDIFF(DAY, LeftDate, DATEFROMPARTS(yl_Year, 12, 31))/365.24 &lt; 0)) THEN 1 ELSE 0 END) AS 'Operation',
		SUM(CASE WHEN UnitId = 3 AND	(DATEDIFF(DAY, DATEFROMPARTS(yl_Year, 12, 31), EffectiveDate)/365.24 &lt; 0) AND (LeftDate IS NULL OR (DATEDIFF(DAY, LeftDate, DATEFROMPARTS(yl_Year, 12, 31))/365.24 &lt; 0)) THEN 1 ELSE 0 END) AS 'Distribution',
		SUM(CASE WHEN UnitId = 2 AND	(DATEDIFF(DAY, DATEFROMPARTS(yl_Year, 12, 31), EffectiveDate)/365.24 &lt; 0) AND (LeftDate IS NULL OR (DATEDIFF(DAY, LeftDate, DATEFROMPARTS(yl_Year, 12, 31))/365.24 &lt; 0)) THEN 1 ELSE 0 END) AS 'Coporate Planning',
		SUM(CASE WHEN UnitId = 4 AND	(DATEDIFF(DAY, DATEFROMPARTS(yl_Year, 12, 31), EffectiveDate)/365.24 &lt; 0) AND (LeftDate IS NULL OR (DATEDIFF(DAY, LeftDate, DATEFROMPARTS(yl_Year, 12, 31))/365.24 &lt; 0)) THEN 1 ELSE 0 END) AS 'CEO Dept.',
		SUM(CASE WHEN					(DATEDIFF(DAY, DATEFROMPARTS(yl_Year, 12, 31), EffectiveDate)/365.24 &lt; 0) AND (LeftDate IS NULL OR (DATEDIFF(DAY, LeftDate, DATEFROMPARTS(yl_Year, 12, 31))/365.24 &lt; 0)) THEN 1 ELSE 0 END) AS Total
	FROM bigtable
	GROUP BY yl_year
),
outp AS (
	SELECT newtabl.*, Total
	FROM
	small_table
	CROSS APPLY(
		VALUES
			(Year,	Operation,			'Operation'),
			(Year,	"Distribution",		'Distribution'),
			(Year,	"Coporate Planning",'Coporate Planning'),
			(Year,	"CEO Dept.",		'CEO Dept.')
	) newtabl(Year, Num, Dept)
)
SELECT * FROM outp;</CommandText><rd:UseGenericDesigner>true</rd:UseGenericDesigner></Query><Fields><Field Name="Year"><DataField>Year</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="Num"><DataField>Num</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="Dept"><DataField>Dept</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="Total"><DataField>Total</DataField><rd:TypeName>System.Int32</rd:TypeName></Field></Fields><Filters><Filter><FilterExpression>=Fields!Year.Value</FilterExpression><Operator>GreaterThanOrEqual</Operator><FilterValues><FilterValue>=Parameters!start_year.Value</FilterValue></FilterValues></Filter><Filter><FilterExpression>=Fields!Year.Value</FilterExpression><Operator>LessThanOrEqual</Operator><FilterValues><FilterValue>=Parameters!end_year.Value</FilterValue></FilterValues></Filter></Filters></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Textbox Name="ReportTitle"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value xml:space="preserve"> </Value><Style><FontFamily>Segoe UI Black</FontFamily><FontSize>28pt</FontSize><Color>White</Color></Style></TextRun><TextRun><Value>Staff Categorized by Department</Value><Style><FontFamily>Arial</FontFamily><FontSize>20pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style /></Paragraph></Paragraphs><rd:WatermarkTextbox>Title</rd:WatermarkTextbox><rd:DefaultName>ReportTitle</rd:DefaultName><Left>0.20709in</Left><Height>0.60417in</Height><Width>5.69792in</Width><Style><Border><Style>None</Style></Border><BackgroundColor>DarkBlue</BackgroundColor><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox><Tablix Name="Tablix1"><TablixCorner><TablixCornerRows><TablixCornerRow><TablixCornerCell><CellContents><Textbox Name="Textbox4"><CanGrow>true</CanGro