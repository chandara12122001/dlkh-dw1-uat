<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df"><df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily><AutoRefresh>0</AutoRefresh><DataSources><DataSource Name="DataSource1"><ConnectionProperties><DataProvider>SQL</DataProvider><ConnectString>Data Source=10.116.17.52;Initial Catalog=HRMIS</ConnectString><Prompt>Specify a user name and password for data source DataSource1:</Prompt></ConnectionProperties><rd:SecurityType>DataBase</rd:SecurityType><rd:DataSourceID>b3d958c6-cab1-4018-a83d-c7e1a1f5b2b2</rd:DataSourceID></DataSource></DataSources><DataSets><DataSet Name="yearlist"><Query><DataSourceName>DataSource1</DataSourceName><CommandText>USE HRMIS;
WITH 
yearlist AS (
    SELECT 
		(SELECT DISTINCT YEAR(MIN(JoinedDate)) FROM Employee) AS Year
		UNION ALL
		SELECT yl.Year + 1 AS Year
    FROM yearlist yl
    WHERE yl.Year + 1 &lt;= YEAR(GetDate())
)
SELECT * FROM yearlist;</CommandText></Query><Fields><Field Name="Year"><DataField>Year</DataField><rd:TypeName>System.Int32</rd:TypeName></Field></Fields></DataSet><DataSet Name="Resignation_by_Department"><Query><DataSourceName>DataSource1</DataSourceName><CommandText>WITH 
yearlist AS (
    SELECT 
		(SELECT DISTINCT YEAR(MIN(JoinedDate)) FROM Employee) AS Year
		UNION ALL
		SELECT yl.Year + 1 AS Year
    FROM yearlist yl
    WHERE yl.Year + 1 &lt;= YEAR(GetDate())
),
Resignation_by_Department AS (
	SELECT
		yl.Year AS Year, 
		Unit.Name AS 'Status',
		SUM(CASE WHEN Unit.UnitId = EmployeeHistory.UnitId	AND (LeftDate BETWEEN DATEFROMPARTS(yl.Year,1,1) AND DATEFROMPARTS(yl.Year,12,31)) AND JoinedDate &lt;= DATEFROMPARTS(yl.Year,12,31) THEN 1 ELSE 0 END) AS Cnt,
		SUM(CASE WHEN Unit.UnitId IS NOT NULL				AND (LeftDate BETWEEN DATEFROMPARTS(yl.Year,1,1) AND DATEFROMPARTS(yl.Year,12,31)) AND JoinedDate &lt;= DATEFROMPARTS(yl.Year,12,31) THEN 1 ELSE 0 END) AS Total
	FROM 
		yearlist yl
		JOIN 
		(Employee 
		INNER JOIN EmployeeHistory	ON Employee.EmployeeId = EmployeeHistory.EmployeeId 
		INNER JOIN Unit				ON EmployeeHistory.UnitId = Unit.UnitId
		) ON 1 = 1
	WHERE Employee.Status = 'Resigned' AND Unit.Type = 'DEP'
	GROUP BY yl.Year, Unit.Name  
)
SELECT * FROM Resignation_by_Department;</CommandText><rd:UseGenericDesigner>true</rd:UseGenericDesigner></Query><Fields><Field Name="Year"><DataField>Year</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="Status"><DataField>Status</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="Cnt"><DataField>Cnt</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="Total"><DataField>Total</DataField><rd:TypeName>System.Int32</rd:TypeName></Field></Fields><Filters><Filter><FilterExpression>=Fields!Year.Value</FilterExpression><Operator>GreaterThanOrEqual</Operator><FilterValues><FilterValue>=Parameters!start_year.Value</FilterValue></FilterValues></Filter><Filter><FilterExpression>=Fields!Year.Value</FilterExpression><Operator>LessThanOrEqual</Operator><FilterValues><FilterValue>=Parameters!end_year.Value</FilterValue></FilterValues></Filter></Filters></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Textbox Name="ReportTitle"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value> Resignation by Department</Value><Style><FontFamily>Arial</FontFamily><FontSize>18pt</FontSize><FontWeight>Normal</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Left</TextAlign></Style></Paragraph></Paragraphs><rd:WatermarkTextbox>Title</rd:WatermarkTextbox><rd:DefaultName>ReportTitle</rd:DefaultName><Left>0.20709in</Left><Height>0.60417in</Height><Width>5.69792in</Width><Style><Border><Style>None</Style></Border><BackgroundColor>DarkBlue</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox><Tablix Name="Tablix1"><TablixCorner><TablixCornerRows><TablixCornerRow><TablixCornerCell><CellContents><Textbox Name="Textbox4"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><Text