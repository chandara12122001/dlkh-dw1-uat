<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df"><df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily><AutoRefresh>0</AutoRefresh><DataSources><DataSource Name="DataSource1"><ConnectionProperties><DataProvider>SQL</DataProvider><ConnectString>Data Source=10.116.17.52;Initial Catalog=HRMIS</ConnectString><Prompt>Specify a user name and password for data source DataSource1:</Prompt></ConnectionProperties><rd:SecurityType>DataBase</rd:SecurityType><rd:DataSourceID>b3d958c6-cab1-4018-a83d-c7e1a1f5b2b2</rd:DataSourceID></DataSource></DataSources><DataSets><DataSet Name="yearlist"><Query><DataSourceName>DataSource1</DataSourceName><CommandText>USE HRMIS;
WITH 
yearlist AS (
    SELECT 
		(SELECT DISTINCT YEAR(MIN(JoinedDate)) FROM Employee) AS Year
		UNION ALL
		SELECT yl.Year + 1 AS Year
    FROM yearlist yl
    WHERE yl.Year + 1 &lt;= YEAR(GetDate())
)
SELECT * FROM yearlist;</CommandText></Query><Fields><Field Name="Year"><DataField>Year</DataField><rd:TypeName>System.Int32</rd:TypeName></Field></Fields></DataSet><DataSet Name="type_of_stuff_seperation"><Query><DataSourceName>DataSource1</DataSourceName><CommandText>USE HRMIS;
WITH 
yearlist AS (
    SELECT 
		(SELECT DISTINCT YEAR(MIN(JoinedDate)) FROM Employee) AS Year
		UNION ALL
		SELECT yl.Year + 1 AS Year
    FROM yearlist yl
    WHERE yl.Year + 1 &lt;= YEAR(GetDate())
),
big_table AS (
	SELECT yl.Year,
		SUM(CASE WHEN /*TODO-Employee.LeftReason = 'RESI' AND */(DATEDIFF(DAY, LeftDate, DATEFROMPARTS(yl.Year,12,31))/365.24 BETWEEN 0 AND 1) THEN 1 ELSE 0 END) AS type1,
		SUM(CASE WHEN /*TODO-Employee.LeftReason = 'TERM' AND */(DATEDIFF(DAY, LeftDate, DATEFROMPARTS(yl.Year,12,31))/365.24 BETWEEN 0 AND 1) THEN 1 ELSE 0 END) AS type2,
		SUM(CASE WHEN /*TODO-Employee.LeftReason = 'MEDI' AND */(DATEDIFF(DAY, LeftDate, DATEFROMPARTS(yl.Year,12,31))/365.24 BETWEEN 0 AND 1) THEN 1 ELSE 0 END) AS type3,
		SUM(CASE WHEN /*TODO-Employee.LeftReason = 'RETI' AND */(DATEDIFF(DAY, LeftDate, DATEFROMPARTS(yl.Year,12,31))/365.24 BETWEEN 0 AND 1) THEN 1 ELSE 0 END) AS type4,
		SUM(CASE WHEN /*TODO-*/ (LeftDate IS NOT NULL		AND (DATEDIFF(DAY, LeftDate, DATEFROMPARTS(yl.Year,12,31))/365.24 BETWEEN 0 AND 1)) THEN 1 ELSE 0 END) AS Total
	FROM 
		yearlist yl
		JOIN Employee ON 1 = 1,
		SystemDefinedFieldList
	WHERE YEAR(JoinedDate) &lt;= yl.Year AND Employee.LeftReason = SystemDefinedFieldList.Code
	GROUP BY yl.Year
),
type_of_stuff_seperation AS(
	SELECT newtabl.*, Total
	FROM
	big_table
	CROSS APPLY(
		VALUES
			(Year,type1, 'Voluntary Resignation'	),	
			(Year,type2, 'Contract Termination'		),			
			(Year,type3, 'Medical Separation'		),			
			(Year,type4, 'Staff Retirement'			)						 
	) newtabl(Year, Num, Dept)
)
SELECT * FROM type_of_stuff_seperation;</CommandText><rd:UseGenericDesigner>true</rd:UseGenericDesigner></Query><Fields><Field Name="Year"><DataField>Year</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="Num"><DataField>Num</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="Dept"><DataField>Dept</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="Total"><DataField>Total</DataField><rd:TypeName>System.Int32</rd:TypeName></Field></Fields><Filters><Filter><FilterExpression>=Fields!Year.Value</FilterExpression><Operator>GreaterThanOrEqual</Operator><FilterValues><FilterValue>=Parameters!start_year.Value</FilterValue></FilterValues></Filter><Filter><FilterExpression>=Fields!Year.Value</FilterExpression><Operator>LessThanOrEqual</Operator><FilterValues><FilterValue>=Parameters!end_year.Value</FilterValue></FilterValues></Filter></Filters></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Textbox Name="ReportTitle"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value> Types of Staff Sepration</Value><Style><FontFamily>Arial</FontFamily><FontSize>18pt</FontSize><FontWeight>Normal</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Left</TextAlign></Style></Paragraph></Paragraphs><rd:WatermarkTextbox>Title</rd:WatermarkTextbox><rd:DefaultName>ReportTitle</rd:DefaultName><Left>0.25917in</Left><Height>0.54514in</Height><Width>5.69792in</Width><Style><Border><Style>None</Style></Border><BackgroundColor>DarkBlue</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox><Tablix Name="Tablix3"><TablixCorner><TablixCornerRows><TablixCornerRow><TablixCornerCell><CellContents><Textbox Name="Textbox16"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns>