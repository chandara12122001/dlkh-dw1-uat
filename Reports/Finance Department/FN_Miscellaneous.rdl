<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df"><df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily><AutoRefresh>0</AutoRefresh><DataSources><DataSource Name="DataSource1"><DataSourceReference>PROD_DB27</DataSourceReference><rd:SecurityType>None</rd:SecurityType><rd:DataSourceID>deb0ad68-85a9-4334-92c6-69c2fc1086c4</rd:DataSourceID></DataSource></DataSources><DataSets><DataSet Name="DataSet1"><Query><DataSourceName>DataSource1</DataSourceName><CommandText>
SELECT POL.POL_ID 
, POL.PXP_PRD_SHR_CD
, POL.POL_MISC_SUSP_DT
,	POL.POL_MISC_SUSP_AMT
--, case when POL.CVG_PREM_PAY_DUR &gt; 5 then POL.ACCT_PRD_CD || 'Y' ELSE POL.ACCT_PRD_CD || 'N' END AS ACCT_PRD_CD
--, case when POL.NEW_TERM &gt; 5 then POL.ACCT_PRD_CD || 'Y' ELSE POL.ACCT_PRD_CD || 'N' END AS ACCT_PRD_CD
,POL.ACCT_PRD_CD || case when POL.YRT_PRODUCT = 'Y' THEN 'N' ELSE CASE WHEN POL.NEW_TERM &gt; 5 then 'Y' ELSE 'N' END END AS ACCT_PRD_CD
, POL.FUND_CD
, TRIM(POL.DM_AV_MODEL_TXT) AS STATUS

FROM 
	(SELECT TPOL.POL_ID, TPOL.POL_MISC_SUSP_DT, TPOL.POL_MISC_SUSP_AMT, B.NEW_TERM, TDMAV.DM_AV_MODEL_TXT, TPOL.PLAN_ID PXP_PRD_SHR_CD, CASE WHEN LEFT(TPOL.PLAN_ID,2)='KB' THEN '1' WHEN LEFT(TPOL.PLAN_ID,2)='DW' THEN '2' ELSE '3' END AS ACCT_PRD_CD, 'PP001' AS FUND_CD, NULL YRT_PRODUCT
	  FROM KCAPXPR1.TPOL AS TPOL		 
			 
			 INNER JOIN (SELECT CO_ID, POL_ID, PLAN_ID
										,YEAR(MAX(CASE WHEN CVG_MAT_XPRY_DT &lt; VALUE(PREV_MAT_XPRY_DT,'1900-01-01') THEN VALUE(PREV_MAT_XPRY_DT,'1900-01-01')
															ELSE CVG_MAT_XPRY_DT END) - (MIN(VALUE(CVG_ISS_EFF_DT, '1900-01-01')) - 1 DAYS)) AS NEW_TERM
									FROM KCAPXPR1.TCVG TCVG WHERE TCVG.CO_ID='CP' 
									GROUP BY TCVG.CO_ID, TCVG.POL_ID, TCVG.PLAN_ID
									) AS B ON TPOL.CO_ID =B.CO_ID AND TPOL.POL_ID=B.POL_ID AND TPOL.PLAN_ID=B.PLAN_ID

			 INNER JOIN KCAPXPR1.TDMAV TDMAV ON TPOL.POL_CSTAT_CD = TDMAV.DM_AV_CD AND TDMAV.DM_AV_TBL_CD = 'POL-CSTAT-CD'
			 
	WHERE TPOL.CO_ID   = 'CP'
    AND TPOL.POL_MISC_SUSP_AMT &lt;&gt; 0   
		 
  ) AS POL					
	
ORDER BY POL.POL_ID	






</CommandText></Query><Fields><Field Name="POL_ID"><DataField>POL_ID</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="PXP_PRD_SHR_CD"><DataField>PXP_PRD_SHR_CD</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="POL_MISC_SUSP_DT"><DataField>POL_MISC_SUSP_DT</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field><Field Name="POL_MISC_SUSP_AMT"><DataField>POL_MISC_SUSP_AMT</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field><Field Name="ACCT_PRD_CD"><DataField>ACCT_PRD_CD</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="FUND_CD"><DataField>FUND_CD</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="STATUS"><DataField>STATUS</DataField><rd:TypeName>System.String</rd:TypeName></Field></Fields></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Tablix Name="Tablix1"><TablixBody><TablixColumns><TablixColumn><Width>1.35833in</Width></TablixColumn><TablixColumn><Width>1.28333in</Width></TablixColumn><TablixColumn><Width>1.33333in</Width></TablixColumn><TablixColumn><Width>1.33333in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>2.95in</Width></TablixColumn></TablixColumns><TablixRows><TablixRow><Height>0.3in</Height><TablixCells><TablixCell><CellContents><Textbox Name="Textbox1"><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value>POL ID</Value><Style><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><rd:DefaultName>Textbox1</rd:DefaultName><Style><Border><Color>#92846e</Color><Style>Solid</Style></Border><BackgroundColor>#c2b7a8</BackgroundColor><VerticalAlign>Middle</VerticalAlign><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Tex