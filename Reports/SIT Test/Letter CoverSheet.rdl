_REL_INSRD_CD</DataField></Field><Field Name="BNFY_PRCDS_PCT"><rd:TypeName>System.Decimal</rd:TypeName><DataField>BNFY_PRCDS_PCT</DataField></Field><Field Name="CLI_BTH_DT"><rd:TypeName>System.DateTime</rd:TypeName><DataField>CLI_BTH_DT</DataField></Field><Field Name="CLI_SEX_CD"><rd:TypeName>System.String</rd:TypeName><DataField>CLI_SEX_CD</DataField></Field><Field Name="CLI_SEX_FULL"><rd:TypeName>System.String</rd:TypeName><DataField>CLI_SEX_FULL</DataField></Field><Field Name="CLI_ID_NUM"><rd:TypeName>System.String</rd:TypeName><DataField>CLI_ID_NUM</DataField></Field><Field Name="POL_ID"><rd:TypeName>System.String</rd:TypeName><DataField>POL_ID</DataField></Field></Fields></DataSet><DataSet Name="DataSet3"><Query><DataSourceName>STAGE</DataSourceName><QueryParameters><QueryParameter Name="@POL"><Value>=Parameters!PolID.Value</Value></QueryParameter></QueryParameters><CommandType>StoredProcedure</CommandType><CommandText>RPT_COVERSHEET_HIS</CommandText></Query><Fields><Field Name="CLI_ID"><rd:TypeName>System.String</rd:TypeName><DataField>CLI_ID</DataField></Field><Field Name="CURR_POL_ID"><rd:TypeName>System.String</rd:TypeName><DataField>CURR_POL_ID</DataField></Field><Field Name="ENTR_SUR_NM"><rd:TypeName>System.String</rd:TypeName><DataField>ENTR_SUR_NM</DataField></Field><Field Name="DIFF_POL_ID"><rd:TypeName>System.String</rd:TypeName><DataField>DIFF_POL_ID</DataField></Field><Field Name="ENTR_GIV_NM"><rd:TypeName>System.String</rd:TypeName><DataField>ENTR_GIV_NM</DataField></Field><Field Name="POL_ID"><rd:TypeName>System.String</rd:TypeName><DataField>POL_ID</DataField></Field><Field Name="CLI_CIN_NUM"><rd:TypeName>System.String</rd:TypeName><DataField>CLI_CIN_NUM</DataField></Field><Field Name="CLI_SEX_CD"><rd:TypeName>System.String</rd:TypeName><DataField>CLI_SEX_CD</DataField></Field><Field Name="CLI_BTH_DT"><rd:TypeName>System.DateTime</rd:TypeName><DataField>CLI_BTH_DT</DataField></Field><Field Name="CLI_CNTCT_ID_TXT"><rd:TypeName>System.String</rd:TypeName><DataField>CLI_CNTCT_ID_TXT</DataField></Field><Field Name="CLI_ADDR_LN_1_TXT"><rd:TypeName>System.String</rd:TypeName><DataField>CLI_ADDR_LN_1_TXT</DataField></Field><Field Name="COMMUNE"><rd:TypeName>System.String</rd:TypeName><DataField>COMMUNE</DataField></Field><Field Name="DISTRICT"><rd:TypeName>System.String</rd:TypeName><DataField>DISTRICT</DataField></Field><Field Name="CITY"><rd:TypeName>System.String</rd:TypeName><DataField>CITY</DataField></Field><Field Name="TYPE"><rd:TypeName>System.String</rd:TypeName><DataField>TYPE</DataField></Field></Fields></DataSet><DataSet Name="ME_INFO"><Query><DataSourceName>SALEPORTAL</DataSourceName><QueryParameters><QueryParameter Name="@PolID"><Value>=Parameters!PolID.Value</Value></QueryParameter></QueryParameters><CommandText>
SELECT AP.policy_id
,AP.number
,RTRIM(PC.name) hosp_name
,RTRIM(MI.appointment_date) appointment_date
,RTRIM(MI.appointment_time) appointment_time
FROM applications AP
LEFT JOIN medical_invitations MI ON MI.application_id = AP.id
LEFT JOIN pannel_clinics PC ON PC.id = MI.panel_clinic_id AND PC.enable = 1
WHERE AP.number IS NOT NULL AND AP.policy_id = @PolID</CommandText></Query><Fields><Field Name="policy_id"><rd:TypeName>System.String</rd:TypeName><DataField>policy_id</DataField></Field><Field Name="number"><rd:TypeName>System.String</rd:TypeName><DataField>number</DataField></Field><Field Name="hosp_name"><rd:TypeName>System.String</rd:TypeName><DataField>hosp_name</DataField></Field><Field Name="appointment_date"><rd:TypeName>System.String</rd:TypeName><DataField>appointment_date</DataField></Field><Field Name="appointment_time"><rd:TypeName>System.String</rd:TypeName><DataField>appointment_time</DataField></Field></Fields></DataSet><DataSet Name="DataSet4"><Query><DataSourceName>STAGE</DataSourceName><QueryParameters><QueryParameter Name="@PolID"><Value>=Parameters!PolID.Value</Value></QueryParameter></QueryParameters><CommandType>StoredProcedure</CommandType><CommandText>RPT_COVER_SHEET_UW_SUMM</CommandText></Query><Fields><Field Name="POL_ID"><rd:TypeName>System.String</rd:TypeName><DataField>POL_ID</DataField></Field><Field Name="UWG_SUMM_TXT"><rd:TypeName>System.String</rd:TypeName><DataField>UWG_SUMM_TXT</DataField></Field><Field Name="UWG_CREAT_USER_ID"><rd:TypeName>System.String</rd:TypeName><DataField>UWG_CREAT_USER_ID</DataField></Field><Field Name="UWG_USER_1_ID"><rd:TypeName>System.String</rd:TypeName><DataField>UWG_USER_1_ID</DataField></Field><Field Name="UWG_CREAT_DT"><rd:TypeName>System.DateTime</rd:TypeName><DataField>UWG_CREAT_DT</DataField></Field><Field Name="UWG_DECID_1_DT"><rd:TypeName>System.DateTime</rd:TypeName><DataField>UWG_DECID_1_DT</DataField></Field><Field Name="UWG_UPDATE_DT"><rd:TypeName>System.DateTime</rd:TypeName><DataField>UWG_UPDATE_DT</DataField></Field><Field Name="UWG_USER_2_ID"><rd:TypeName>System.String</rd:TypeName><DataField>UWG_USER_2_ID</DataField></Field><Field Name="UWG_DECID_2_DT"><rd:TypeName>System.DateTime</rd:TypeName><DataField>UWG_DECID_2_DT</DataField></Field><Field Name="UWG_SUMM_1_TXT"><rd:TypeName>System.String</rd:TypeName><DataField>UWG_SUMM_1_TXT</DataField></Field><Field Name="UWG_SUMM_CSTAT_1_CD"><rd:TypeName>System.String</rd:TypeName><DataField>UWG_SUMM_CSTAT_1_CD</DataField></Field><Field Name="UWG_SUMM_2_TXT"><rd:TypeName>System.String</rd:TypeName><DataField>UWG_SUMM_2_TXT</DataField></Field><Field Name="UWG_SUMM_CSTAT_2_CD"><rd:TypeName>System.String</rd:TypeName><DataField>UWG_SUMM_CSTAT_2_CD</DataField></Field><Field Name="UWG_SUMM_CSTAT_1_DESC"><rd:TypeName>System.String</rd:TypeName><DataField>UWG_SUMM_CSTAT_1_DESC</DataField></Field><Field Name="UWG_SUMM_CSTAT_2_DESC"><rd:TypeName>System.String</rd:TypeName><DataField>UWG_SUMM_CSTAT_2_DESC</DataField></Field></Fields></DataSet><DataSet Name="DataSet5"><Query><DataSourceName>STP</DataSourceName><QueryParameters><QueryParameter Name="PolID"><rd:UserDefined>true</rd:UserDefined><Value>=Parameters!PolID.Value</Value></QueryParameter></QueryParameters><rd:UseGenericDesigner>true</rd:UseGenericDesigner><CommandText>select  r.application_number, r.policy_number
,string_agg(rd.rule_code  || ':' || rd.rule_result_code , ',') AS rule_codes
from "result" r 
left join result_detail rd on rd.result_id =r.id 
--left join auw_result_detail ard  on ard.result_id = r.id 
--where r.policy_number = $PolID
group by r.application_number, r.policy_number</CommandText></Query><Fields><Field Name="application_number"><rd:TypeName>System.String</rd:TypeName><DataField>application_number</DataField></Field><Field Name="policy_number"><rd:TypeName>System.String</rd:TypeName><DataField>policy_number</DataField></Field><Field Name="rule_codes"><rd:TypeName>System.String</rd:TypeName><DataField>rule_codes</DataField></Field></Fields><Filters><Filter><FilterExpression>=Fields!policy_number.Value</FilterExpression><Operator>Equal</Operator><FilterValues><FilterValue>=Parameters!PolID.Value</FilterValue></FilterValues></Filter></Filters></DataSet><DataSet Name="OCR"><Query><DataSourceName>SALEPORTAL</DataSourceName><QueryParameters><QueryParameter Name="@PolID"><Value>=Parameters!PolID.Value</Value></QueryParameter></QueryParameters><CommandText>SELECT CASE WHEN COUNT(*) &gt; 0 THEN 'OCR' ELSE 'Non-OCR' END IS_OCR FROM client_ocrs o
LEFT JOIN applications A ON A.id = O.application_id 
WHERE A.policy_id = @PolID</CommandText></Query><Fields><Field Name="IS_OCR"><rd:TypeName>System.String</rd:TypeName><DataField>IS_OCR</DataField></Field></Fields></DataSet><DataSet Name="AmlResult"><Query><DataSourceName>STP</DataSourceName><QueryParameters><QueryParameter Name="?"><Value>=Parameters!PolID.Value</Value></QueryParameter></QueryParameters><CommandText>select distinct on (a.client_id)
	a.client_id,
	a.first_name,
	a.last_name,
	a.gender,
	a.date_of_birth,
	c.name_en as pob_en,
	left(concat(case a.po when true then 'PO, ' else '' end,
		case a.bli when true then 'BLI, ' else '' end,
		case a.ali when true then 'ALI, ' else '' end,
		case a.ben when true then 'BEN, ' else '' end), -2) as role,
	a.matched,
	a.created_at
from aml_screening_results a
left join countries c on c.ing_code = a.ing_country_code
where a.policy_id = ?
order by a.client_id, a.created_at desc</CommandText></Query><Fields><Field Name="client_id"><rd:TypeName>System.String</rd:TypeName><DataField>client_id</DataField></Field><Field Name="first_name"><rd:TypeName>System.String</rd:TypeName><DataField>first_name</DataField></Field><Field Name="last_name"><rd:TypeName>System.String</rd:TypeName><DataField>last_name</DataField></Field><Field Name="gender"><rd:TypeName>System.String</rd:TypeName><DataField>gender</DataField></Field><Field Name="date_of_birth"><rd:TypeName>System.DateTime</rd:TypeName><DataField>date_of_birth</DataField></Field><Field Name="pob_en"><rd:TypeName>System.String</rd:TypeName><DataField>pob_en</DataField></Field><Field Name="role"><rd:TypeName>System.String</rd:TypeName><DataField>role</DataField></Field><Field Name="matched"><rd:TypeName>System.String</rd:TypeName><DataField>matched</DataField></Field><Field Name="created_at"><rd:TypeName>System.DateTime</rd:TypeName><DataField>created_at</DataField></Field></Fields></DataSet><DataSet Name="CaseInfo"><Query><DataSourceName>SALEPORTAL</DataSourceName><QueryParameters><QueryParameter Name="@PolID"><Value>=Parameters!PolID.Value</Value></QueryParameter></QueryParameters><CommandText>select
    loan = case when exists (
        select li.id from loan_information li
        inner join applications a on a.quotation_id = li.quotation_id
        where a.policy_id = @PolID and li.enable = 1
    ) or exists (
        select lc.id from loan_contracts lc
        inner join applications a on a.id = lc.application_id
        where a.policy_id = @PolID
    ) then 1 else 0 end</CommandText></Query><Fields><Field Name="loan"><rd:TypeName>System.Int32</rd:TypeName><DataField>loan</DataField></Field></Fields></DataSet><DataSet Name="LoanMember"><Query><DataSourceName>SALEPORTAL</DataSourceName><QueryParameters><QueryParameter Name="@PolID"><Value>=Parameters!PolID.Value</Value></QueryParameter></QueryParameters><CommandText>WITH SimplifyLoan AS (
    SELECT
        name = CONCAT(lib.first_name, ' ', lib.last_name),
        dob = lib.dob,
        gender = lib.gender,
        birth_country = CASE WHEN lib.policy_owner = 1 THEN udfl.name_en ELSE NULL END,
        role = CASE WHEN lib.policy_owner = 1 THEN 'PO' ELSE NULL END,
        type = CASE lib.type 
                WHEN 'borrower' THEN 'Borrower'
                WHEN 'co-borrower' THEN 'Co-Borrower'
            END
    FROM loan_information_borrower lib
    LEFT JOIN loan_information linfo ON linfo.id = lib.loan_id
    LEFT JOIN applications a ON a.quotation_id = linfo.quotation_id
    LEFT JOIN customers c ON c.life_insured_id = linfo.life_insured_id
    LEFT JOIN user_defined_field_lists udfl 
        ON udfl.code = c.birth_location 
        AND udfl.user_defined_field_code = 'btloc'
    WHERE a.policy_id = @PolID
    AND linfo.enable = 1
    AND lib.enable = 1
)

SELECT * FROM SimplifyLoan

UNION ALL

SELECT
    name = CONCAT(c.last_name, ' ', c.first_name),
    dob = c.date_of_birth,
    gender = c.gender,
    birth_country = udfl.name_en,
    role = 'PO',
    type = 'Borrower'
FROM customers c
INNER JOIN loan_contracts lc ON lc.application_id = c.application_id
LEFT JOIN applications a ON a.id = c.application_id
LEFT JOIN user_defined_field_lists udfl 
       ON udfl.code = c.birth_location 
      AND udfl.user_defined_field_code = 'btloc'
WHERE a.policy_id = @PolID
    AND c.policy_owner = 1
    AND NOT EXISTS (SELECT 1 FROM SimplifyLoan)

UNION ALL

SELECT
    name = lc.co_borrower_name,
    dob = null,
    gender = null,
    birth_country = null,
    role = null,
    type = 'Co-Borrower'
FROM loan_contracts lc
LEFT JOIN applications a ON a.id = lc.application_id
WHERE a.policy_id = @PolID
    AND lc.co_borrower_name IS NOT NULL AND lc.co_borrower_name &lt;&gt; ''
    AND NOT EXISTS (SELECT 1 FROM SimplifyLoan)

ORDER BY type</CommandText></Query><Fields><Field Name="name"><rd:TypeName>System.String</rd:TypeName><DataField>name</DataField></Field><Field Name="dob"><rd:TypeName>System.DateTime</rd:TypeName><DataField>dob</DataField></Field><Field Name="gender"><rd:TypeName>System.String</rd:TypeName><DataField>gender</DataField></Field><Field Name="birth_country"><rd:TypeName>System.String</rd:TypeName><DataField>birth_country</DataField></Field><Field Name="role"><rd:TypeName>System.String</rd:TypeName><DataField>role</DataField></Field><Field Name="type"><rd:TypeName>System.String</rd:TypeName><DataField>type</DataField></Field></Fields></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Tablix Name="Tablix2"><TablixBody><TablixColumns><TablixColumn><Width>0.35029in</Width></TablixColumn><TablixColumn><Width>0.35029in</Width></TablixColumn><TablixColumn><Width>0.20466in</Width></TablixColumn><TablixColumn><Width>0.49592in</Width></TablixColumn><TablixColumn><Width>0.80029in</Width></TablixColumn><TablixColumn><Width>0.67925in</Width></TablixColumn><TablixColumn><Width>0.12133in</Width></TablixColumn><TablixColumn><Width>0.42091in</Width></TablixColumn><TablixColumn><Width>0.37967in</Width></TablixColumn><TablixColumn><Width>0.46904in</Width></TablixColumn><TablixColumn><Width>0.13154in</Width></TablixColumn><TablixColumn><Width>0.60029in</Width></TablixColumn><TablixColumn><Width>0.70029in</Width></TablixColumn><TablixColumn><Width>0.04591in</Width></TablixColumn><TablixColumn><Width>0.45467in</Width></TablixColumn><TablixColumn><Width>0.70029in</Width></TablixColumn><TablixColumn><Width>0.82035in</Width></TablixColumn></TablixColumns><TablixRows><TablixRow><Height>0.03125in</Height><TablixCells><TablixCell><CellContents><Textbox Name="Textbox92"><rd:DefaultName>Textbox92</rd:DefaultName><CanGrow>true</CanGrow><KeepTogether>true</KeepTogether><Paragraphs><Paragraph><TextRuns><TextRun><Value /><Style><FontFamily>dubai</FontFamily><FontSize>8pt</FontSize>