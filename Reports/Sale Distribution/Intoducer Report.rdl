<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily" MustUnderstand="df"><df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily><AutoRefresh>0</AutoRefresh><DataSources><DataSource Name="STAGE_PROD7"><ConnectionProperties><DataProvider>SQL</DataProvider><ConnectString>Data Source=10.116.17.52;Initial Catalog=DLKHSTAGE</ConnectString><IntegratedSecurity>true</IntegratedSecurity></ConnectionProperties><rd:SecurityType>Integrated</rd:SecurityType><rd:DataSourceID>1695a8fc-3848-4551-8fd5-93aaaecd1e7a</rd:DataSourceID></DataSource><DataSource Name="KIZUNA"><ConnectionProperties><DataProvider>SQL</DataProvider><ConnectString>Data Source=10.116.17.104;Initial Catalog=ERFDB_UAT</ConnectString><IntegratedSecurity>true</IntegratedSecurity></ConnectionProperties><rd:SecurityType>Integrated</rd:SecurityType><rd:DataSourceID>ec12fe44-16c3-4e42-9815-db42aa05ede3</rd:DataSourceID></DataSource></DataSources><DataSets><DataSet Name="DataSet1"><Query><DataSourceName>KIZUNA</DataSourceName><CommandText>



SELECT A.CODE INTRO_CODE,  CONCAT(A.last_name,' ',A.first_name) INTRO_NAME, A.gender,A.date_of_birth, A.status, POSITION = 'ITD'
, CAST(A.created_at AS DATE) EFFECTIVE_DATE, CASE WHEN A.status = 'inactive' then CAST(a.updated_at AS DATE) ELSE NULL END TERMINATION_DSATE
, A.primary_phone_number, A.secondary_phone_number, A.uid ID_NUMBER
,ISNULL(M.TOTAL_MITT_PHEAK,0) TOTAL_MITT_PHEAK
,ISNULL(P.TOTAL_ISS_POL,0) TOTAL_ISS_POL
,A.agent_code
,CONCAT(AG.last_name,' ',AG.first_name) agent_name
FROM introducers A
LEFT JOIN agents AG ON AG.code = A.agent_code
LEFT JOIN (SELECT introducer_code, COUNT(code) TOTAL_MITT_PHEAK FROM mittpheaks GROUP BY introducer_code) M ON M.introducer_code = A.code
LEFT JOIN (SELECT INTRO_ID, COUNT(*) TOTAL_ISS_POL FROM kizuna_policy WHERE POL_CSTAT_CD = '1' GROUP BY INTRO_ID) P ON P.INTRO_ID = A.code
</CommandText></Query><Fields><Field Name="INTRO_CODE"><DataField>INTRO_CODE</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="INTRO_NAME"><DataField>INTRO_NAME</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="gender"><DataField>gender</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="date_of_birth"><DataField>date_of_birth</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field><Field Name="status"><DataField>status</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="POSITION"><DataField>POSITION</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="AGENT_NAME"><DataField>agent_name</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="EFFECTIVE_DATE"><DataField>EFFECTIVE_DATE</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field><Field Name="TERMINATION_DSATE"><DataField>TERMINATION_DSATE</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field><Field Name="primary_phone_number"><DataField>primary_phone_number</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="secondary_phone_number"><DataField>secondary_phone_number</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="ID_NUMBER"><DataField>ID_NUMBER</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="TOTAL_MITT_PHEAK"><DataField>TOTAL_MITT_PHEAK</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="TOTAL_ISS_POL"><DataField>TOTAL_ISS_POL</DataField><rd:TypeName>System.Int32</rd:TypeName></Field><Field Name="agent_code"><DataField>agent_code</DataField><rd:TypeName>System.String</rd:TypeName></Field></Fields></DataSet><DataSet Name="DataSet2"><Query><DataSourceName>STAGE_PROD7</DataSourceName><CommandText>
SELECT AgentId, Name, LeaderId,LeaderName,ManagerId,ManagerName,Branch, DistributionChannel CHANNEL FROM SGTM_AGENT_DETAIL</CommandText></Query><Fields><Field Name="AgentId"><DataField>AgentId</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="Name"><DataField>Name</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="LeaderId"><DataField>LeaderId</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="LeaderName"><DataField>LeaderName</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="ManagerId"><DataField>ManagerId</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="ManagerName"><DataField>ManagerName</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="Branch"><DataField>Branch</DataField><rd:TypeName>System.String</rd:TypeName></Field><Field Name="CHANNEL"><DataField>CHANNEL</DataField><rd:TypeName>System.String</rd:TypeName></Field></Fields></DataSet></DataSets><ReportSections><ReportSection><Body><ReportItems><Tablix Name="Tablix1"><TablixBody><TablixColumns><TablixColumn><Width>0.5in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1.8in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1.3in</Width></TablixColumn><TablixColumn><Width>1.3in</Width></TablixColumn><TablixColumn><Width>1.3in</Width></TablixColumn><TablixColumn><Width>1.8in</Width></TablixColumn><TablixColumn><Width>0.8in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColumn><TablixColumn><Width>1.8in</Width></TablixColumn><TablixColumn><Width>1in</Width></TablixColu